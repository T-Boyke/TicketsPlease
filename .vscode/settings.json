{
  "dotnet.server.useOmnisharp": false,
  "csharp.format.enable": true,
  "csharp.analysis.showFullSolutionAnalysis": true,
  "csharp.documentation.showXmlDocumentation": true,
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit"
  },
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": "active",
  "editor.stickyScroll.enabled": true,
  "editor.renderWhitespace": "selection",
  "editor.suggestSelection": "first",
  "editor.rulers": [80, 100, 120],
  "markdownlint.config": {
    "extends": ".config/.markdownlint.json"
  },
  "markdownlint.run": "onSave",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "files.associations": {
    "*.cshtml": "razor",
    "*.css": "tailwindcss"
  },
  "files.autoSave": "onFocusChange",
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "tailwindCSS.experimental.classRegex": [
    ["class\\s*=\\s*\"([^\"]*)\"", "([^\\s\"']+)"],
    ["class\\s*=\\s*'([^']*)'", "([^\\s\"']+)"],
    ["@utility\\s+([^\\s{]+)", "([^\\s{]+)"],
    ["classNames\\(([^)]*)\\)", "[\"'`]([^\"'`]*)[\"'`]"],
    ["(?<=\\b(?:class|className)\\s*:\\s*['\"])([^'\"]*)"],
    "class: \"([^\"]*)\""
  ],
  "tailwindCSS.includeLanguages": {
    "aspnetcorerazor": "html",
    "razor": "html",
    "cshtml": "html",
    "csharp": "html"
  },
  "tailwindCSS.classAttributes": [
    "class",
    "className",
    "asp-class",
    "active-class"
  ],
  "tailwindCSS.classFunctions": [
    "clsx",
    "twMerge",
    "classNames",
    "cn",
    "twJoin"
  ],
  "tailwindCSS.lint.invalidApply": "error",
  "tailwindCSS.lint.invalidScreen": "error",
  "tailwindCSS.lint.invalidVariant": "error",
  "tailwindCSS.lint.invalidTailwindDirective": "error",
  "tailwindCSS.validate": true,
  "tailwindCSS.emmetCompletions": true,
  "tailwindCSS.showPixelEquivalents": true,
  "tailwindCSS.colorDecorators": true,
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[css]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "efcore.defaultProject": "src/TicketsPlease.Infrastructure/TicketsPlease.Infrastructure.csproj",
  "efcore.defaultStartupProject": "src/TicketsPlease.Web/TicketsPlease.Web.csproj",
  "playwright.testDir": "tests/TicketsPlease.E2ETests",
  "playwright.reuseBrowser": true,
  "css.validate": false,
  "sonarlint.pathToCompileCommands": "",
  "sonarlint.testFilePattern": "{**/tests/**,**/*Tests.cs,**/*Test.cs}",
  "sonarlint.rules": {
    "csharpsquid:S1135": { "level": "off" },
    "css:S4667": { "level": "off" },
    "css:S4666": { "level": "off" }
  },
  "sonarlint.analyzerProperties": {
    "sonar.cs.ignore.generated.code": "true"
  },
  "sonarlint.connectedMode.project": {
    "projectKey": "TicketsPlease"
  },
  "css.lint.unknownAtRules": "ignore",
  "dotnet.unitTestDebuggingOptions": {
    "env": {
      "PWDEBUG": "0",
      "ASPNETCORE_ENVIRONMENT": "Development"
    }
  },
  "cSpell.words": [
    "abarbeitbare",
    "abteilungsspezifischen",
    "antigravity",
    "appsettings",
    "Auschecken",
    "Avatare",
    "Barrierefreiheitsstärkungsgesetz",
    "BFSG",
    "buildtransitive",
