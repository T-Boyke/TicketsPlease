# Auto detect text files and perform LF normalization
* text=auto

# C# / .NET specific
*.cs text eol=lf
*.cshtml text eol=lf
*.razor text eol=lf
*.sln text eol=lf
*.slnx text eol=lf
*.csproj text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.config text eol=lf
*.settings text eol=lf
*.resx text eol=lf
*.pubxml text eol=lf

# Web / Frontend
*.js text eol=lf
*.ts text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf

# Graphics / Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.dll binary
*.exe binary
*.pdb binary
