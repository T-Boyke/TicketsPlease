@using Microsoft.AspNetCore.Mvc.Localization
@using TicketsPlease.Application.Common.Dtos
@model IEnumerable<TicketDto>
@inject IViewLocalizer L

@{
    ViewData["Title"] = L["Ticket Board"];
    ViewData["Description"] = L["Manage your team tasks and project progress on the interactive Ticket Please Kanban board."].Value;
    var todo = Model.Where(t => t.Status == "Todo");
    var doing = Model.Where(t => t.Status == "Doing" || t.Status == "In Progress");
    var done = Model.Where(t => t.Status == "Closed" || t.Status == "Done");
}

<div class="max-w-[1600px] mx-auto py-8 px-4 sm:px-6 lg:px-8 h-[calc(100vh-12rem)] flex flex-col">
    @Html.AntiForgeryToken()
    @* Header Section *@
    <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
        <div>
            <nav class="flex mb-2" aria-label="Breadcrumb">
                <ol class="flex items-center space-x-2 text-xs font-semibold text-slate-400">
                    <li><a asp-controller="Home" asp-action="Index" class="hover:text-brand-primary transition-colors">@L["Dashboard"]</a></li>
                    <li><i class="fa-solid fa-chevron-right text-[10px]"></i></li>
                    <li class="text-slate-600">@L["Ticket Board"]</li>
                </ol>
            </nav>
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">@L["Project Board"]</h1>
        </div>
        <div class="flex items-center space-x-3">
            <form asp-action="Index" method="get" class="relative group hidden sm:block">
                <input type="hidden" name="projectId" value='@ViewData["CurrentProject"]' />
                <input type="hidden" name="assignedUserId" value='@ViewData["CurrentAssignee"]' />
                <input type="hidden" name="creatorId" value='@ViewData["CurrentCreator"]' />
                <i class="fa-solid fa-magnifying-glass absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 group-focus-within:text-brand-primary transition-colors"></i>
                <input type="text" name="search" value='@ViewData["CurrentSearch"]' placeholder="@L["Search tickets..."]" class="pl-10 pr-4 py-2 bg-slate-100 border-none rounded-full text-sm focus:ring-2 focus:ring-brand-primary/20 focus:bg-white w-64 transition-all" />
            </form>
            <a asp-action="Create" class="inline-flex items-center px-5 py-2.5 rounded-full bg-brand-primary text-white text-sm font-bold hover:bg-brand-secondary hover:shadow-lg hover:shadow-brand-primary/30 transition-all duration-200">
                <i class="fa-solid fa-plus mr-2"></i>
                @L["New Ticket"]
            </a>
        </div>
    </div>

    @* Filter Bar (F6) *@
    <div class="bg-white rounded-2xl p-4 border border-slate-100 shadow-md mb-8 flex flex-wrap items-center gap-6">
        <div class="flex items-center text-slate-400 font-bold text-[10px] uppercase tracking-widest border-r border-slate-100 pr-6">
            <i class="fa-solid fa-filter mr-2 text-brand-primary"></i> @L["Filter"]
        </div>
        
        <form asp-action="Index" method="get" class="flex flex-wrap items-center gap-4">
            @* Project Filter *@
            <div class="flex flex-col">
                <label for="filter-project" class="text-[9px] font-bold text-slate-400 uppercase mb-1 ml-1">@L["Project"]</label>
                <select id="filter-project" name="projectId" class="bg-slate-50 border-none text-slate-700 text-xs font-bold rounded-lg focus:ring-2 focus:ring-brand-primary/20 block px-3 py-2 transition-all outline-none min-w-[140px]" onchange="this.form.submit()">
                    <option value="">@L["All Projects"]</option>
                    @foreach (var p in (SelectList)ViewBag.Projects)
                    {
                        <option value="@p.Value" selected='@(ViewData["CurrentProject"]?.ToString() == p.Value)'>@p.Text</option>
                    }
                </select>
            </div>

            @* Priority Filter *@
            <div class="flex flex-col">
                <label for="filter-priority" class="text-[9px] font-bold text-slate-400 uppercase mb-1 ml-1">@L["Priority"]</label>
                <select id="filter-priority" name="priorityId" class="bg-slate-50 border-none text-slate-700 text-xs font-bold rounded-lg focus:ring-2 focus:ring-brand-primary/20 block px-3 py-2 transition-all outline-none min-w-[120px]" onchange="this.form.submit()">
                    <option value="">@L["All Priorities"]</option>
                    @foreach (var p in (SelectList)ViewBag.Priorities)
                    {
                        <option value="@p.Value" selected='@(ViewData["CurrentPriority"]?.ToString() == p.Value)'>@p.Text</option>
                    }
                </select>
            </div>

            @* Tag Filter *@
            <div class="flex flex-col">
                <label for="filter-tag" class="text-[9px] font-bold text-slate-400 uppercase mb-1 ml-1">@L["Tag"]</label>
                <select id="filter-tag" name="tagId" class="bg-slate-50 border-none text-slate-700 text-xs font-bold rounded-lg focus:ring-2 focus:ring-brand-primary/20 block px-3 py-2 transition-all outline-none min-w-[120px]" onchange="this.form.submit()">
                    <option value="">@L["All Tags"]</option>
                    @foreach (var t in (IEnumerable<TagDto>)ViewBag.Tags.Items)
                    {
                        <option value="@t.Id" selected='@(ViewData["CurrentTag"]?.ToString() == t.Id.ToString())'>#@t.Name</option>
                    }
                </select>
            </div>

            @* Assignee Filter *@
            <div class="flex flex-col">
                <label for="filter-assignee" class="text-[9px] font-bold text-slate-400 uppercase mb-1 ml-1">@L["Assignee"]</label>
                <select id="filter-assignee" name="assignedUserId" class="bg-slate-50 border-none text-slate-700 text-xs font-bold rounded-lg focus:ring-2 focus:ring-brand-primary/20 block px-3 py-2 transition-all outline-none min-w-[140px]" onchange="this.form.submit()">
                    <option value="">@L["All Assignees"]</option>
                    @foreach (var u in (SelectList)ViewBag.Users)
                    {
                        <option value="@u.Value" selected='@(ViewData["CurrentAssignee"]?.ToString() == u.Value)'>@u.Text</option>
                    }
                </select>
            </div>

            @* Hidden persistent search *@
            <input type="hidden" name="search" value='@ViewData["CurrentSearch"]' />

            @if (ViewData["CurrentProject"] != null || ViewData["CurrentAssignee"] != null || ViewData["CurrentPriority"] != null || ViewData["CurrentTag"] != null || !string.IsNullOrWhiteSpace(ViewData["CurrentSearch"] as string))
            {
                <div class="flex items-end h-full pb-2">
                    <a asp-action="Index" class="text-[10px] font-bold text-rose-500 hover:text-rose-600 transition-colors flex items-center bg-rose-50 px-3 py-1.5 rounded-full">
                        <i class="fa-solid fa-xmark mr-1"></i> @L["Clear Filters"]
                    </a>
                </div>
            }
        </form>
    </div>

    @* Kanban Grid *@
    <div id="kanban-board" class="flex-grow grid grid-cols-1 md:grid-cols-3 gap-6 overflow-hidden">
        
        @* To Do Column *@
        <div class="flex flex-col h-full bg-slate-50/50 rounded-2xl border border-slate-200/60 p-4 max-h-[80vh] overflow-hidden">
            <div class="flex items-center justify-between mb-4 px-2">
                <div class="flex items-center space-x-2">
                    <span class="h-2 w-2 rounded-full bg-slate-400"></span>
                    <h2 class="text-sm font-bold text-slate-600 uppercase tracking-wider">@L["To Do"]</h2>
                    <span id="todo-count" class="ml-2 px-2 py-0.5 rounded-full bg-slate-200 text-slate-500 text-[10px] font-bold">@todo.Count()</span>
                </div>
                <button class="text-slate-400 hover:text-slate-600"><i class="fa-solid fa-ellipsis"></i></button>
            </div>
            <div id="todo-list" class="flex-grow overflow-y-auto min-h-[500px] max-h-[65vh] space-y-4 pr-2 custom-scrollbar" data-status="Todo">
                @foreach (var ticket in todo)
                {
                    <partial name="_TicketCard" model="ticket" />
                }
            </div>
        </div>

        @* In Progress Column *@
        <div class="flex flex-col h-full bg-brand-primary/5 rounded-2xl border border-brand-primary/20 p-4 max-h-[80vh] overflow-hidden">
            <div class="flex items-center justify-between mb-4 px-2">
                <div class="flex items-center space-x-2">
                    <span class="h-2 w-2 rounded-full bg-amber-500"></span>
                    <h2 class="text-sm font-bold text-slate-700 uppercase tracking-wider">@L["In Progress"]</h2>
                    <span id="doing-count" class="ml-2 px-2 py-0.5 rounded-full bg-brand-primary/10 text-brand-primary text-[10px] font-bold">@doing.Count()</span>
                </div>
                <button class="text-slate-400 hover:text-brand-primary" aria-label='@L["Column Actions"]'><i class="fa-solid fa-ellipsis" aria-hidden="true"></i></button>
            </div>
            <div id="doing-list" class="flex-grow overflow-y-auto min-h-[500px] max-h-[65vh] space-y-4 pr-2 custom-scrollbar" data-status="In Progress">
                @foreach (var ticket in doing)
                {
                    <partial name="_TicketCard" model="ticket" />
                }
            </div>
        </div>

        @* Done Column *@
        <div class="flex flex-col h-full bg-emerald-50/50 rounded-2xl border border-emerald-200/60 p-4 max-h-[80vh] overflow-hidden">
            <div class="flex items-center justify-between mb-4 px-2">
                <div class="flex items-center space-x-2">
                    <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
                    <h2 class="text-sm font-bold text-slate-600 uppercase tracking-wider">@L["Done"]</h2>
                    <span id="done-count" class="ml-2 px-2 py-0.5 rounded-full bg-emerald-200 text-emerald-600 text-[10px] font-bold">@done.Count()</span>
                </div>
                <button class="text-slate-400 hover:text-emerald-600" aria-label='@L["Column Actions"]'><i class="fa-solid fa-ellipsis" aria-hidden="true"></i></button>
            </div>
            <div id="done-list" class="flex-grow overflow-y-auto min-h-[500px] max-h-[65vh] space-y-4 pr-2 custom-scrollbar" data-status="Done">
                @foreach (var ticket in done)
                {
                    <partial name="_TicketCard" model="ticket" />
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/sortablejs/Sortable.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const lists = ['todo-list', 'doing-list', 'done-list'];
            
            lists.forEach(id => {
                const el = document.getElementById(id);
                Sortable.create(el, {
                    group: 'kanban',
                    animation: 150,
                    ghostClass: 'opacity-50',
                    dragClass: 'rotate-2',
                    onEnd: function(evt) {
                        const ticketId = evt.item.dataset.id;
                        const newStatus = evt.to.dataset.status;
                        const oldStatus = evt.from.dataset.status;
                        
                        if (newStatus === oldStatus) return;

                        // Update counts locally immediately
                        const updateCounts = () => {
                            document.getElementById('todo-count').innerText = document.getElementById('todo-list').children.length;
                            document.getElementById('doing-count').innerText = document.getElementById('doing-list').children.length;
                            document.getElementById('done-count').innerText = document.getElementById('done-list').children.length;
                        };
                        updateCounts();

                        const formData = new URLSearchParams();
                        formData.append('__RequestVerificationToken', document.querySelector('input[name="__RequestVerificationToken"]').value);

                        fetch(`/Tickets/Move/${ticketId}?status=${newStatus}`, {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/x-www-form-urlencoded'
                            },
                            body: formData
                        }).then(response => {
                            if (!response.ok) {
                                console.error('Move failed');
                                location.reload();
                            }
                        }).catch(() => {
                            location.reload();
                        });
                    }
                });
            });
        });
    </script>
}

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #cbd5e1; }
</style>
