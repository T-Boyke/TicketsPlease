@using Microsoft.AspNetCore.Mvc.Localization
@using TicketsPlease.Application.Common.Dtos
@model TicketDto
@inject IViewLocalizer L

@{
    ViewData["Title"] = $"{Model.Title} | {Model.ProjectTitle}";
    ViewData["Description"] = $"{L["Details for ticket"].Value} {Model.Title}: {Model.Description.Substring(0, Math.Min(Model.Description.Length, 150))}...";
}

<div id="ticket-details-container" data-ticket-id="@Model.Id" class="max-w-5xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="mb-8 px-6 py-4 rounded-2xl bg-rose-50 border border-rose-100 text-rose-600 font-bold flex items-center shadow-sm animate-pulse">
            <i class="fa-solid fa-circle-exclamation mr-3 text-rose-500 text-xl"></i>
            @TempData["ErrorMessage"]
        </div>
    }
    <div class="flex items-center justify-between mb-8">
        <a asp-action="Index" class="text-slate-400 hover:text-brand-primary font-bold transition-colors flex items-center">
            <i class="fa-solid fa-arrow-left mr-2"></i> @L["Back to Board"]
        </a>
        <div class="flex space-x-3">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="px-5 py-2.5 rounded-full border border-slate-200 text-slate-600 font-bold hover:bg-slate-50 transition-all">
                <i class="fa-solid fa-pen mr-2"></i> @L["Edit"]
            </a>
            @if (Model.Status != "Closed")
            {
                <form asp-action="Move" asp-route-id="@Model.Id" asp-route-status="Closed" method="post" class="inline">
                    <button type="submit" class="px-5 py-2.5 rounded-full bg-emerald-500 text-white font-bold hover:bg-emerald-600 hover:shadow-lg hover:shadow-emerald-500/30 transition-all">
                        <i class="fa-solid fa-check mr-2"></i> @L["Close Ticket"]
                    </button>
                </form>
            }
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        @* Main Content *@
        <div class="lg:col-span-2 space-y-8">
            <div class="bg-white rounded-3xl p-8 border border-slate-100 shadow-xl">
                <div class="flex-grow">
                    <div class="flex items-center gap-4 mb-4">
                        <span class="text-xs font-black px-4 py-1.5 rounded-full uppercase tracking-widest shadow-sm ring-1 ring-inset" 
                              style="background-color: @(Model.Priority.ColorHex + "10"); color: @(Model.Priority.ColorHex); ring-color: @(Model.Priority.ColorHex + "30")">
                            @Model.Priority.Name
                        </span>
                        <form asp-action="ToggleUpvote" method="post" class="inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <button type="submit" class="flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-black uppercase tracking-widest transition-all @(Model.UserHasUpvoted ? "bg-rose-500 text-white shadow-lg shadow-rose-500/30" : "bg-slate-100 text-slate-500 hover:bg-rose-50 hover:text-rose-500")" aria-label='@L["Toggle Upvote"]'>
                                <i class="fa-solid fa-heart @(Model.UserHasUpvoted ? "animate-pulse" : "")" aria-hidden="true"></i>
                                <span>@Model.UpvoteCount</span>
                            </button>
                        </form>
                        <span class="text-xs font-bold text-slate-400 uppercase tracking-widest bg-slate-100 px-4 py-1.5 rounded-full">@Model.ProjectTitle</span>
                    </div>
                    <div class="flex flex-col mb-6 empty:hidden" id="presence-section">
                        <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">@L["Current viewers"]</span>
                        <div id="ticket-presence-container" class="flex flex-wrap gap-2">
                             @* Wird via SignalR befüllt *@
                        </div>
                    </div>
                    <h1 class="text-4xl font-extrabold text-slate-900 mb-6 leading-tight">@Model.Title</h1>
                </div>
                
                <div class="flex items-center space-x-3 mb-6">
                    <div class="flex items-center space-x-1" title="@L["Difficulty"]: @Model.ChilliesDifficulty / 5">
                        @for (int i = 1; i <= 5; i++)
                        {
                            var color = i switch {
                                1 => "#15803d",
                                2 => "#84cc16",
                                3 => "#f59e0b",
                                4 => "#f97316",
                                5 => "#e11d48",
                                _ => "#cbd5e1"
                            };
                            
                            if (i <= Model.ChilliesDifficulty)
                            {
                                <i class="fa-solid fa-pepper-hot @(i == 5 ? "animate-pulse" : "")" style="color: @color"></i>
                            }
                            else
                            {
                                <i class="fa-solid fa-pepper-hot text-slate-200"></i>
                            }
                        }
                    </div>
                    <span class="text-slate-400 font-bold text-sm">TICKET-@Model.Id.ToString().Substring(0, 8).ToUpper()</span>
                </div>
                
                @if (Model.Tags.Any())
                {
                    <div class="flex flex-wrap gap-2 mb-6">
                        @foreach (var tag in Model.Tags)
                        {
                            <span class="px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider border transition-all hover:shadow-sm"
                                  style="background-color: @(tag.ColorHex + "15"); color: @tag.ColorHex; border-color: @(tag.ColorHex + "30")">
                                <i class="fa-solid fa-tag mr-1 opacity-70"></i>@tag.Name
                            </span>
                        }
                    </div>
                }
                <div class="prose prose-slate max-w-none mb-8">
                    <h3 class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-4">@L["Description"]</h3>
                    <div class="markdown-content text-slate-700 leading-relaxed invisible">@Model.Description</div>
                </div>

                @* Audit Log Section (Phase 3 Premium) *@
                <div class="mt-12 pt-8 border-t border-slate-100">
                    <h3 class="text-xl font-bold text-slate-800 mb-6 flex items-center">
                        <i class="fa-solid fa-history mr-3 text-indigo-500" aria-hidden="true"></i> @L["Audit Log"]
                    </h3>
                    <div class="space-y-4 max-h-[300px] overflow-y-auto pr-4 custom-scrollbar">
                        @if (!Model.History.Any())
                        {
                            <p class="text-xs text-slate-400 italic">@L["No history records yet."]</p>
                        }
                        else
                        {
                            @foreach (var log in Model.History)
                            {
                                <div class="flex items-start gap-4 p-4 rounded-2xl bg-slate-50 border border-slate-100">
                                    <div class="h-8 w-8 rounded-full bg-white shadow-sm flex items-center justify-center text-xs font-black text-brand-primary">
                                        @(log.ChangedByUserName.Substring(0, 1).ToUpper())
                                    </div>
                                    <div class="flex-1">
                                        <div class="flex items-center justify-between mb-1">
                                            <span class="text-[10px] font-black uppercase text-brand-primary">@log.ChangedByUserName</span>
                                            <span class="text-[10px] font-bold text-slate-400">@log.ChangedAt.ToLocalTime().ToString("g")</span>
                                        </div>
                                        <p class="text-xs text-slate-600">
                                           @L["Changed"] <span class="font-bold text-slate-800">@log.ChangeType</span>: 
                                           <span class="text-rose-500 line-through">@log.OldValue</span> 
                                           <i class="fa-solid fa-arrow-right mx-1 text-slate-300"></i> 
                                           <span class="text-emerald-500 font-bold">@log.NewValue</span>
                                        </p>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <!-- Checklist Section (F2.1.7) -->
                <div class="pt-8 border-t border-slate-100">
                    <div class="flex items-center justify-between mb-6">
                        <h3 class="text-xl font-bold text-slate-800 flex items-center">
                            <i class="fa-solid fa-list-check mr-3 text-indigo-500" aria-hidden="true"></i> @L["Checklist"]
                        </h3>
                        @{
                            int totalSub = Model.SubTickets.Count();
                            int completedSub = Model.SubTickets.Count(s => s.IsCompleted);
                            int progressPercent = totalSub > 0 ? (completedSub * 100) / totalSub : 0;
                        }
                        <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">@completedSub / @totalSub @L["Completed"]</span>
                    </div>

                    <!-- Progress Bar -->
                    <div class="w-full bg-slate-100 rounded-full h-2 mb-8 overflow-hidden">
                        <div class="bg-indigo-500 h-full transition-all duration-700 ease-in-out" style="width: @progressPercent%"></div>
                    </div>

                    <div class="space-y-3 mb-8">
                        @foreach (var sub in Model.SubTickets)
                        {
                            <div class="group flex items-center bg-slate-50 hover:bg-white p-4 rounded-2xl border border-transparent hover:border-slate-100 transition-all shadow-sm hover:shadow-md">
                                <form asp-action="ToggleSubTicket" method="post" class="flex-1 flex items-center">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <input type="hidden" name="subTicketId" value="@sub.Id" />
                                    <button type="submit" class="flex items-center text-left w-full group/btn" aria-label='@L["Toggle completion for"] @sub.Title'>
                                        <div class="w-6 h-6 rounded-lg border-2 flex items-center justify-center transition-all mr-4 @(sub.IsCompleted ? "bg-emerald-500 border-emerald-500 shadow-lg shadow-emerald-500/20" : "border-slate-300 group-hover/btn:border-indigo-500")">
                                            @if (sub.IsCompleted)
                                            {
                                                <i class="fa-solid fa-check text-white text-[10px]" aria-hidden="true"></i>
                                            }
                                        </div>
                                        <span class="text-slate-700 font-bold text-sm @(sub.IsCompleted ? "line-through text-slate-400 font-medium" : "")">@sub.Title</span>
                                    </button>
                                </form>
                                
                                <form asp-action="DeleteSubTicket" method="post" class="opacity-0 group-hover:opacity-100 transition-opacity">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@Model.Id" />
                                    <input type="hidden" name="subTicketId" value="@sub.Id" />
                                    <button type="submit" class="text-slate-300 hover:text-rose-500 transition-colors p-2" onclick="return confirm('@L["Are you sure?"]')" aria-label='@L["Delete task"]'>
                                        <i class="fa-solid fa-trash-can text-sm" aria-hidden="true"></i>
                                    </button>
                                </form>
                            </div>
                        }

                        @* Add SubTask Form *@
                        <form asp-action="AddSubTicket" method="post" class="flex items-center space-x-3 mt-4">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.Id" />
                            <div class="relative flex-1">
                                <i class="fa-solid fa-plus absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 text-xs" aria-hidden="true"></i>
                                <input type="text" name="title" placeholder="@L["Add a new task..."]" required aria-label='@L["Task title"]'
                                       class="w-full pl-11 pr-4 py-3 bg-slate-50 border border-slate-100 rounded-2xl focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all outline-none text-sm font-medium" />
                            </div>
                            <button type="submit" class="bg-indigo-500 text-white p-3 rounded-2xl hover:bg-indigo-600 shadow-lg shadow-indigo-500/20 transition-all" aria-label='@L["Add task"]'>
                                <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
                            </button>
                        </form>
                    </div>

                @* Comments Section (F5) *@
                <div class="pt-8 border-t border-slate-100">
                    <h3 class="text-xl font-bold text-slate-800 mb-6 flex items-center">
                        <i class="fa-solid fa-comments mr-3 text-indigo-500" aria-hidden="true"></i> @L["Comments"] (@Model.Comments.Count())
                    </h3>

                    @* Comment Form *@
                    <form asp-controller="Comment" asp-action="Create" method="post" class="mb-8 p-6 bg-slate-50 rounded-2xl border border-slate-100 shadow-sm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="TicketId" value="@Model.Id" />
                        <div class="mb-4">
                            <textarea name="Content" rows="3" required aria-label='@L["Comment content"]' class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition-all outline-none resize-none bg-white font-medium text-slate-700" placeholder="@L["Write a comment... (Markdown supported)"]"></textarea>
                        </div>
                        <div class="flex justify-end">
                            <button type="submit" class="px-6 py-2.5 rounded-full bg-indigo-500 text-white font-bold hover:bg-indigo-600 hover:shadow-lg hover:shadow-indigo-500/30 transition-all flex items-center">
                                <i class="fa-solid fa-paper-plane mr-2" aria-hidden="true"></i> @L["Post Comment"]
                            </button>
                        </div>
                    </form>

                    @* Comment List *@
                    <div id="comments-list" data-ticket-id="@Model.Id" class="space-y-6">
                        @if (!Model.Comments.Any())
                        {
                            <div class="text-center py-12 bg-slate-50 rounded-2xl border border-dashed border-slate-200">
                                <i class="fa-solid fa-comment-slash text-slate-300 text-3xl mb-3 block" aria-hidden="true"></i>
                                <p class="text-slate-400 font-medium">@L["No comments yet. Be the first to start the discussion!"]</p>
                            </div>
                        }
                        else
                        {
                            @foreach (var comment in Model.Comments)
                            {
                                <div class="flex space-x-4 p-5 rounded-2xl hover:bg-slate-50 transition-all border border-transparent hover:border-slate-100 group">
                                    @{
                                        string initials = "??";
                                        if (comment.AuthorName?.Length >= 2)
                                        {
                                            initials = comment.AuthorName.Substring(0, 2).ToUpper();
                                        }
                                        else if (comment.AuthorName?.Length == 1)
                                        {
                                            initials = comment.AuthorName.ToUpper() + "?";
                                        }
                                    }
                                    <partial name="_Avatar" model='initials' view-data='@new ViewDataDictionary(ViewData) { { "SizeClass", "h-10 w-10 flex-shrink-0" } }' />
                                    <div class="flex-1">
                                        <div class="flex items-center justify-between mb-1">
                                            <span class="font-bold text-slate-900 group-hover:text-indigo-600 transition-colors">@comment.AuthorName</span>
                                            <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">@comment.CreatedAt.ToLocalTime().ToString("g")</span>
                                        </div>
                                        <div class="markdown-content text-slate-600 text-sm leading-relaxed invisible">@comment.Content</div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        @* Sidebar *@
        <div class="space-y-6">
            <div class="bg-white rounded-3xl p-6 border border-slate-100 shadow-xl">
                <h3 class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-6">@L["Properties"]</h3>
                <div class="space-y-6">
                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter mb-1">@L["Status"]</p>
                        <div class="inline-flex items-center px-3 py-1 rounded-full bg-slate-100 text-slate-700 text-xs font-bold">
                            @Model.Status
                        </div>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter mb-1">@L["Assignee"]</p>
                        <div class="flex items-center space-x-3">
                            <partial name="_Avatar" model='Model.AssignedUserName.Substring(0, 2).ToUpper()' view-data='@new ViewDataDictionary(ViewData) { { "SizeClass", "h-8 w-8" } }' />
                            <span class="text-sm font-bold text-slate-700">@Model.AssignedUserName</span>
                        </div>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter mb-1">@L["Project"]</p>
                        <p class="text-sm font-bold text-slate-700">@Model.ProjectTitle</p>
                    </div>
                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter mb-1">@L["Created"]</p>
                        <p class="text-sm font-bold text-slate-700">@Model.CreatedAt.ToString("g")</p>
                    </div>
                </div>
            </div>

            @* Time Tracking (F2.1.4) *@
            <div class="bg-white rounded-3xl p-6 border border-slate-100 shadow-xl overflow-hidden relative">
                @if (Model.IsTimerRunning)
                {
                    <div class="absolute top-0 right-0 p-2">
                        <span class="flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-rose-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-rose-500"></span>
                        </span>
                    </div>
                }
                <h3 class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-6 flex items-center">
                    <i class="fa-solid fa-clock-rotate-left mr-2 text-brand-primary"></i> @L["Time Tracking"]
                </h3>
                
                <div class="flex items-center justify-between mb-6">
                    <div>
                        <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">@@L["Total"]</p>
                        <p class="text-2xl font-black text-slate-900">@Model.TimeLogs.Sum(l => l.HoursLogged).ToString("F2") <span class="text-xs font-normal text-slate-400">h</span></p>
                    </div>
                    @if (Model.IsTimerRunning)
                    {
                        <form asp-action="StopTimer" asp-route-id="@Model.Id" method="post">
                            <button type="submit" class="bg-rose-500 hover:bg-rose-600 text-white rounded-xl px-4 py-2 text-[10px] font-bold uppercase transition-all shadow-lg shadow-rose-500/30 flex items-center">
                                <i class="fa-solid fa-stop mr-1.5"></i> @L["Stop"]
                            </button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="StartTimer" asp-route-id="@Model.Id" method="post">
                            <button type="submit" class="bg-emerald-500 hover:bg-emerald-600 text-white rounded-xl px-4 py-2 text-[10px] font-bold uppercase transition-all shadow-lg shadow-emerald-500/30 flex items-center">
                                <i class="fa-solid fa-play mr-1.5"></i> @L["Start"]
                            </button>
                        </form>
                    }
                </div>

                @if (Model.TimeLogs.Any())
                {
                    <div class="space-y-4 max-h-[200px] overflow-y-auto pr-2 custom-scrollbar">
                        @foreach (var log in Model.TimeLogs)
                        {
                            <div class="bg-slate-50 rounded-xl p-3 border border-slate-100/50">
                                <div class="flex justify-between items-start mb-1">
                                    <span class="text-[9px] font-bold text-brand-primary uppercase">@log.UserName</span>
                                    <span class="text-[9px] font-bold text-slate-400">@log.StartedAt.ToLocalTime().ToString("g")</span>
                                </div>
                                <div class="flex justify-between items-center">
                                    <p class="text-[10px] text-slate-600 overflow-hidden text-ellipsis whitespace-nowrap mr-2">@(log.Description ?? "-")</p>
                                    <span class="text-[11px] font-black text-slate-900">@log.HoursLogged.ToString("F2")h</span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-[10px] text-slate-400 italic text-center py-2 opacity-60">@L["No records yet."]</p>
                }
            </div>

            @* Dependencies Section (F7) *@
            <div class="bg-white rounded-3xl p-6 border border-slate-100 shadow-xl">
                <h3 class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-6 flex items-center">
                    <i class="fa-solid fa-link mr-2 text-brand-primary"></i> @L["Dependencies"]
                </h3>
                
                @* Blocked By (Predecessors) *@
                <div class="mb-6">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter mb-3 flex items-center">
                        <i class="fa-solid fa-lock mr-2"></i> @L["Blocked By"]
                    </p>
                    <div class="space-y-3">
                        @foreach (var link in Model.BlockedBy)
                        {
                            <div class="flex items-center justify-between group">
                                <a asp-action="Details" asp-route-id="@link.SourceTicketId" class="text-sm font-bold @(link.IsClosed ? "text-slate-400 line-through" : "text-slate-700 hover:text-brand-primary") transition-colors truncate flex-1 mr-2" title="@link.SourceTicketTitle">
                                    @link.SourceTicketTitle
                                </a>
                                <form asp-action="RemoveDependency" asp-route-id="@Model.Id" asp-route-dependencyId="@link.Id" method="post" class="opacity-0 group-hover:opacity-100 transition-opacity">
                                    <button type="submit" class="text-slate-300 hover:text-rose-500 transition-colors"><i class="fa-solid fa-xmark"></i></button>
                                </form>
                            </div>
                        }
                        @if (!Model.BlockedBy.Any())
                        {
                            <p class="text-xs text-slate-400 italic">@L["No blockers"]</p>
                        }
                    </div>
                </div>

                @* Add Dependency Form *@
                <form asp-action="AddDependency" asp-route-id="@Model.Id" method="post" class="pt-5 border-t border-slate-100">
                    <div class="flex flex-col space-y-2">
                        <select name="blockerId" class="w-full bg-slate-50 border-none text-slate-700 text-xs font-bold rounded-xl focus:ring-2 focus:ring-brand-primary/20 block px-3 py-2 transition-all outline-none" asp-items="ViewBag.AllTickets">
                            <option value="">-- @L["Add Blocker"] --</option>
                        </select>
                        <button type="submit" class="w-full py-2 bg-slate-900 text-white text-[10px] font-bold uppercase tracking-widest rounded-xl hover:bg-slate-800 transition-all">
                            <i class="fa-solid fa-plus mr-1"></i> @L["Add"]
                        </button>
                    </div>
                </form>
                
                @* Blocking (Successors) *@
                <div class="mt-8 pt-6 border-t border-slate-100">
                    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter mb-3 flex items-center">
                        <i class="fa-solid fa-unlock mr-2"></i> @L["Blocking"]
                    </p>
                    <div class="space-y-3">
                        @foreach (var link in Model.Blocking)
                        {
                            <div class="flex items-center justify-between group">
                                <a asp-action="Details" asp-route-id="@link.TargetTicketId" class="text-sm font-bold @(link.IsClosed ? "text-slate-400 line-through" : "text-slate-700 hover:text-brand-primary") transition-colors truncate flex-1 mr-2" title="@link.TargetTicketTitle">
                                    @link.TargetTicketTitle
                                </a>
                                <form asp-action="RemoveDependency" asp-route-id="@Model.Id" asp-route-dependencyId="@link.Id" method="post" class="opacity-0 group-hover:opacity-100 transition-opacity">
                                    <button type="submit" class="text-slate-300 hover:text-rose-500 transition-colors"><i class="fa-solid fa-xmark"></i></button>
                                </form>
                            </div>
                        }
                        @if (!Model.Blocking.Any())
                        {
                            <p class="text-xs text-slate-400 italic">@L["No successors"]</p>
                        }
                    </div>
                </div>
            </div>

            @* Attachments Section (F3) *@
            <div class="bg-white rounded-3xl p-6 border border-slate-100 shadow-xl">
                <h3 class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-6 flex items-center">
                    <i class="fa-solid fa-paperclip mr-2 text-brand-primary"></i> @L["Attachments"]
                </h3>
                
                <div class="space-y-4 mb-6">
                    @if (!Model.Attachments.Any())
                    {
                        <p class="text-xs text-slate-400 italic">@L["No attachments"]</p>
                    }
                    @foreach (var file in Model.Attachments)
                    {
                        <div class="flex items-center justify-between p-3 rounded-2xl bg-slate-50 border border-slate-100 group hover:border-brand-primary/30 transition-all">
                            <div class="flex items-center space-x-3 overflow-hidden">
                                <div class="h-8 w-8 rounded-lg bg-white flex items-center justify-center text-brand-primary border border-slate-100 flex-shrink-0">
                                    <i class="fa-solid fa-file"></i>
                                </div>
                                <div class="overflow-hidden">
                                    <p class="text-xs font-bold text-slate-700 truncate" title="@file.FileName">@file.FileName</p>
                                    <p class="text-[10px] text-slate-400 font-bold uppercase tracking-wider">@(Math.Round(file.SizeBytes / 1024.0, 1)) KB</p>
                                </div>
                            </div>
                            <a asp-action="DownloadAttachment" asp-route-id="@file.Id" class="text-slate-400 hover:text-brand-primary transition-colors">
                                <i class="fa-solid fa-download"></i>
                            </a>
                        </div>
                    }
                </div>

                <form asp-action="UploadAttachment" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" class="pt-5 border-t border-slate-100">
                    <div class="flex flex-col space-y-3">
                        <label class="relative block">
                            <span class="sr-only">Choose file</span>
                            <input type="file" name="file" class="block w-full text-xs text-slate-500
                                file:mr-4 file:py-2 file:px-4
                                file:rounded-full file:border-0
                                file:text-[10px] file:font-extrabold file:uppercase file:tracking-widest
                                file:bg-slate-100 file:text-slate-700
                                hover:file:bg-slate-200 file:cursor-pointer transition-all focus:outline-none" required />
                        </label>
                        <button type="submit" class="w-full py-2 bg-indigo-500 text-white text-[10px] font-bold uppercase tracking-widest rounded-xl hover:bg-indigo-600 hover:shadow-lg hover:shadow-indigo-500/30 transition-all">
                            <i class="fa-solid fa-upload mr-1 text-[8px]"></i> @L["Upload"]
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
