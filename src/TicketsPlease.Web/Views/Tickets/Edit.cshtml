@using Microsoft.AspNetCore.Mvc.Localization
@using TicketsPlease.Application.Common.Dtos
@model UpdateTicketDto
@inject IViewLocalizer L

@{
    ViewData["Title"] = L["Edit Ticket"];
}

<div class="max-w-3xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <div class="bg-white shadow-2xl rounded-3xl overflow-hidden border border-slate-100">
        <div class="bg-slate-50 px-8 py-10 border-b border-slate-100 relative">
            <a asp-action="Index" class="absolute top-10 right-8 text-slate-400 hover:text-brand-primary transition-colors">
                <i class="fa-solid fa-xmark text-2xl"></i>
            </a>
            <h1 class="text-2xl font-extrabold text-slate-900">@L["Edit Ticket"]</h1>
            <p class="text-slate-500 mt-1">@L["Update the details and progress of this task."]</p>
        </div>

        <form asp-action="Edit" method="post" class="p-8 space-y-6">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="RowVersion" />
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="md:col-span-2">
                    <label asp-for="Title" for="Title" class="block text-sm font-bold text-slate-700">@L["Ticket Title"]</label>
                    <input asp-for="Title" id="Title" class="mt-1 block w-full px-4 py-3 border border-slate-300 rounded-xl shadow-sm focus:ring-2 focus:ring-brand-primary/20 focus:border-brand-primary transition-all sm:text-sm" />
                    <span asp-validation-for="Title" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div class="md:col-span-2">
                    <label asp-for="Description" for="Description" class="block text-sm font-bold text-slate-700">@L["Description"]</label>
                    <textarea asp-for="Description" id="Description" rows="4" class="mt-1 block w-full px-4 py-3 border border-slate-300 rounded-xl shadow-sm focus:ring-2 focus:ring-brand-primary/20 focus:border-brand-primary transition-all sm:text-sm"></textarea>
                    <span asp-validation-for="Description" class="text-red-500 text-xs mt-1"></span>
                </div>

                <div>
                    <label asp-for="Status" for="Status" class="block text-sm font-bold text-slate-700">@L["Status"]</label>
                    <select asp-for="Status" id="Status" class="mt-1 block w-full px-4 py-3 border border-slate-300 rounded-xl shadow-sm focus:ring-2 focus:ring-brand-primary/20 focus:border-brand-primary transition-all sm:text-sm">
                        <option value="Todo">@L["To Do"]</option>
                        <option value="Doing">@L["In Progress"]</option>
                        <option value="Closed">@L["Done / Closed"]</option>
                    </select>
                </div>

                <div>
                    <label asp-for="PriorityId" for="PriorityId" class="block text-sm font-bold text-slate-700">@L["Priority"]</label>
                    <select asp-for="PriorityId" id="PriorityId" asp-items="ViewBag.Priorities" class="mt-1 block w-full px-4 py-3 border border-slate-300 rounded-xl shadow-sm focus:ring-2 focus:ring-brand-primary/20 focus:border-brand-primary transition-all sm:text-sm"></select>
                </div>

                <div>
                    <label asp-for="AssignedUserId" for="AssignedUserId" class="block text-sm font-bold text-slate-700">@L["Assignee"]</label>
                    <select asp-for="AssignedUserId" id="AssignedUserId" asp-items="ViewBag.Users" class="mt-1 block w-full px-4 py-3 border border-slate-300 rounded-xl shadow-sm focus:ring-2 focus:ring-brand-primary/20 focus:border-brand-primary transition-all sm:text-sm">
                        <option value="">@L["No Assignee"]</option>
                    </select>
                </div>

                <div>
                    <label asp-for="EstimatePoints" for="EstimatePoints" class="block text-sm font-bold text-slate-700">@L["Story Points"]</label>
                    <input asp-for="EstimatePoints" id="EstimatePoints" type="number" min="0" class="mt-1 block w-full px-4 py-3 border border-slate-300 rounded-xl shadow-sm focus:ring-2 focus:ring-brand-primary/20 focus:border-brand-primary transition-all sm:text-sm" />
                </div>

                <div>
                    <label asp-for="ChilliesDifficulty" class="block text-sm font-bold text-slate-700 mb-2">@L["Difficulty (Chilis)"]</label>
                    <div class="flex items-center space-x-2 bg-slate-50 p-2.5 rounded-xl border border-slate-200">
                        @for (int i = 1; i <= 5; i++)
                        {
                            var color = i switch {
                                1 => "#15803d",
                                2 => "#84cc16",
                                3 => "#f59e0b",
                                4 => "#f97316",
                                5 => "#e11d48",
                                _ => "#cbd5e1"
                            };
                            <label class="cursor-pointer group">
                                <input type="radio" asp-for="ChilliesDifficulty" value="@i" class="sr-only peer" />
                                <i class="fa-solid fa-pepper-hot text-xl transition-all peer-checked:scale-125 text-slate-300 hover:text-rose-300 peer-checked:![color:@color]"></i>
                            </label>
                        }
                    </div>
                </div>

                <div class="md:col-span-2">
                    <div class="flex items-center justify-between mb-2">
                        <label asp-for="TagIds" class="text-sm font-bold text-slate-700">@L["Tags"]</label>
                        <button type="button" onclick="openTagModal()" class="text-xs font-bold text-brand-primary hover:text-brand-secondary flex items-center">
                            <i class="fa-solid fa-plus-circle mr-1"></i>
                            @L["Add New Tag"]
                        </button>
                    </div>

                    <div id="tag-container" class="flex flex-wrap gap-2 p-4 bg-slate-50 rounded-xl border border-slate-200 min-h-[60px]">
                         @foreach (var tag in (IEnumerable<SelectListItem>)ViewBag.Tags)
                         {
                             bool isSelected = Model.TagIds?.Contains(Guid.Parse(tag.Value)) ?? false;
                             <label class="cursor-pointer">
                                 <input type="checkbox" name="TagIds" value="@tag.Value" class="sr-only peer" @(isSelected ? "checked" : "") />
                                 <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-bold transition-all border border-transparent
                                              bg-white text-slate-600 shadow-sm hover:border-slate-300
                                              peer-checked:bg-brand-primary/10 peer-checked:border-brand-primary peer-checked:text-brand-primary">
                                     @tag.Text
                                 </span>
                             </label>
                         }
                    </div>
                </div>
            </div>

            <div class="pt-6 border-t border-slate-100 flex justify-end space-x-4">
                <a asp-action="Index" class="px-6 py-3 border border-slate-200 text-slate-600 font-bold rounded-xl hover:bg-slate-50 transition-colors">@L["Cancel"]</a>
                <button type="submit" class="px-10 py-3 bg-brand-primary text-white font-bold rounded-xl hover:bg-brand-secondary hover:shadow-xl hover:shadow-brand-primary/30 transition-all active:scale-95">@L["Save Changes"]</button>
            </div>
        </form>
    </div>
</div>

<!-- Tag Modal -->
<div id="tagModal" class="fixed inset-0 z-50 hidden overflow-y-auto">
    <div class="flex items-center justify-center min-h-screen p-4 text-center">
        <div class="fixed inset-0 transition-opacity bg-slate-900/60" onclick="closeTagModal()"></div>
        <div class="relative w-full max-w-md p-8 bg-white rounded-3xl shadow-2xl animate-in zoom-in-95 duration-200">
            <h3 class="text-xl font-extrabold text-slate-900 mb-6">@L["Create New Tag"]</h3>

            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-bold text-slate-700 text-left mb-1">@L["Tag Name"]</label>
                    <input type="text" id="newTagName" placeholder="e.g. UX-Improvement" class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-brand-primary/20" />
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-700 text-left mb-1">@L["Color"]</label>
                    <input type="color" id="newTagColor" value="#3B82F6" class="w-full h-12 p-1 border border-slate-300 rounded-xl cursor-pointer" />
                </div>

                <div>
                    <label class="block text-sm font-bold text-slate-700 text-left mb-1">@L["Icon (FontAwesome)"]</label>
                    <input type="text" id="newTagIcon" value="fa-tag" placeholder="fa-bug, fa-star..." class="w-full px-4 py-3 border border-slate-300 rounded-xl focus:ring-2 focus:ring-brand-primary/20" />
                </div>
            </div>

            <div class="flex justify-end space-x-3 mt-8">
                <button type="button" onclick="closeTagModal()" class="px-6 py-2 text-sm font-bold text-slate-500 hover:text-slate-700">@L["Cancel"]</button>
                <button type="button" onclick="saveNewTag()" class="px-8 py-2 bg-brand-primary text-white text-sm font-bold rounded-xl hover:bg-brand-secondary transition-all">@L["Create"]</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openTagModal() {
            document.getElementById('tagModal').classList.remove('hidden');
        }

        function closeTagModal() {
            document.getElementById('tagModal').classList.add('hidden');
        }

        async function saveNewTag() {
            const name = document.getElementById('newTagName').value;
            const color = document.getElementById('newTagColor').value;
            const icon = document.getElementById('newTagIcon').value;

            if (!name) return;

            try {
                const response = await fetch('/Tickets/CreateTag', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify({ name, color, icon })
                });

                if (response.ok) {
                    const tag = await response.json();

                    // Add to UI
                    const container = document.getElementById('tag-container');
                    const label = document.createElement('label');
                    label.className = 'cursor-pointer';
                    label.innerHTML = `
                        <input type="checkbox" name="TagIds" value="${tag.id}" class="sr-only peer" checked />
                        <span class="inline-flex items-center px-3 py-1.5 rounded-full text-xs font-bold transition-all border border-transparent
                                     bg-white text-slate-600 shadow-sm hover:border-slate-300
                                     peer-checked:bg-brand-primary/10 peer-checked:border-brand-primary peer-checked:text-brand-primary">
                            ${tag.name}
                        </span>
                    `;
                    container.appendChild(label);

                    closeTagModal();
                    document.getElementById('newTagName').value = '';
                }
            } catch (error) {
                console.error('Error creating tag:', error);
            }
        }
    </script>
}
