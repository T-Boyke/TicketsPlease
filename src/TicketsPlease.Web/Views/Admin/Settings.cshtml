@{
    ViewData["Title"] = "System Infrastructure Control";
}

<div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <header class="mb-12">
        <div class="flex items-center gap-2 text-xs font-black text-rose-500 uppercase tracking-widest mb-4">
            <i class="fa-solid fa-shield-halved"></i>
            <span>System Administration</span>
            <span class="h-1 w-1 rounded-full bg-slate-300"></span>
            <span class="text-slate-900">Infrastructure Maintenance</span>
        </div>
        <h1 class="text-4xl font-black text-slate-900 tracking-tight">System Controls</h1>
        <p class="mt-3 text-lg text-slate-500">Configure global application parameters and perform critical maintenance operations.</p>
    </header>

    @if (TempData["StatusMessage"] != null)
    {
        <div class="mb-8 p-6 bg-slate-900 text-white rounded-3xl flex items-center gap-4 animate-in slide-in-from-top-4 shadow-xl">
            <i class="fa-solid fa-circle-check text-emerald-400 text-xl"></i>
            <span class="font-bold">@TempData["StatusMessage"]</span>
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="mb-8 p-6 bg-rose-50 border border-rose-100 rounded-3xl text-rose-700">
            <div asp-validation-summary="All" class="font-bold"></div>
        </div>
    }

    <div class="space-y-12">
        @* Danger Zone *@
        <section class="bg-white rounded-[2.5rem] p-10 border-2 border-rose-100 shadow-2xl relative overflow-hidden group">
            <div class="absolute -right-8 -top-8 text-rose-500/5 text-[10rem] pointer-events-none group-hover:scale-110 transition-transform duration-1000">
                <i class="fa-solid fa-triangle-exclamation"></i>
            </div>

            <div class="flex items-center justify-between mb-8">
                <h2 class="text-3xl font-black text-slate-900">Danger Zone</h2>
                <div class="px-4 py-1.5 bg-rose-500 text-white text-[10px] font-black uppercase tracking-widest rounded-full">Highly Destructive</div>
            </div>

            <p class="text-slate-500 font-medium mb-12 max-w-2xl">
                The operations below are irrevocable. They bypass standard protection layers and interact directly with the database engine. 
                <span class="text-rose-600 font-black">Requires the security phrase "DELETE CONFIRM".</span>
            </p>

            <form asp-action="WipeDatabase" method="post" class="p-8 bg-rose-50 rounded-3xl border border-rose-100 mb-8">
                @Html.AntiForgeryToken()
                <div class="flex flex-col md:flex-row md:items-end gap-6">
                    <div class="flex-grow">
                        <h4 class="text-xl font-black text-rose-900 mb-2">Total Database Reset (Wipe)</h4>
                        <p class="text-sm text-rose-700/70 mb-6 font-medium">Deletes the entire database schema and recreates it. ALL DATA WILL BE LOST!</p>
                        <input type="text" name="confirmPhrase" placeholder="Type 'DELETE CONFIRM' here..." 
                               class="w-full bg-white border-2 border-rose-200 rounded-2xl px-6 py-4 outline-none focus:border-rose-500 transition-all font-black text-rose-900 shadow-sm" required />
                    </div>
                    <button type="submit" class="whitespace-nowrap px-10 py-5 bg-rose-600 text-white rounded-2xl font-black text-lg hover:bg-rose-700 active:scale-95 transition-all shadow-xl shadow-rose-200">
                        Initiate Wipe
                    </button>
                </div>
            </form>

            <form asp-action="TruncateTable" method="post" class="p-8 bg-slate-50 rounded-3xl border border-slate-100">
                @Html.AntiForgeryToken()
                <div class="flex flex-col md:flex-row md:items-end gap-6">
                    <div class="flex-grow">
                        <h4 class="text-xl font-black text-slate-900 mb-2">Targeted Table Truncate</h4>
                        <p class="text-sm text-slate-500 mb-6 font-medium">Select a specific table to empty. Other tables remain untouched.</p>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                             <select name="tableName" class="w-full bg-white border-2 border-slate-200 rounded-2xl px-6 py-4 font-bold text-slate-900" required>
                                 <option value="Tickets">Tickets (Archive All)</option>
                                 <option value="Messages">Messages (Clear History)</option>
                                 <option value="Notifications">Notifications (Clear All)</option>
                                 <option value="TimeLogs">TimeLogs (Reset Tracking)</option>
                             </select>
                             <input type="text" name="confirmPhrase" placeholder="Confirm Phrase..." 
                                    class="w-full bg-white border-2 border-slate-200 rounded-2xl px-6 py-4 outline-none focus:border-indigo-500 transition-all font-black text-slate-900 shadow-sm" required />
                        </div>
                    </div>
                    <button type="submit" class="whitespace-nowrap px-10 py-5 bg-slate-900 text-white rounded-2xl font-black text-lg hover:bg-black active:scale-95 transition-all shadow-xl shadow-slate-200">
                        Empty Table
                    </button>
                </div>
            </form>
        </section>
    </div>
</div>
