@{
    ViewData["Title"] = "UI Styleguide";
}

<div class="px-4 py-8 mx-auto max-w-7xl sm:px-6 lg:px-8">
    <div class="mb-12 border-b border-slate-200 pb-8">
        <h1 class="text-4xl font-extrabold tracking-tight text-slate-900">UI Styleguide & Design System</h1>
        <p class="mt-4 text-xl text-slate-500">
            Diese Seite dient als "Living Documentation" für alle UI-Komponenten des TicketsPlease-Projekts.
            Nutze sie, um visuelle Konsistenz zu gewährleisten.
        </p>
    </div>

    <!-- 1. Design Tokens -->
    <section class="mb-16">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">1. Design Tokens (Farben)</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
            <div class="space-y-2">
                <div class="h-24 w-full rounded-lg bg-brand-primary shadow-sm border border-slate-200"></div>
                <p class="font-medium text-sm">Brand Primary</p>
                <code class="text-xs text-slate-500">var(--brand-primary)</code>
            </div>
            <div class="space-y-2">
                <div class="h-24 w-full rounded-lg bg-brand-secondary shadow-sm border border-slate-200"></div>
                <p class="font-medium text-sm">Brand Secondary</p>
                <code class="text-xs text-slate-500">var(--brand-secondary)</code>
            </div>
            <div class="space-y-2">
                <div class="h-24 w-full rounded-lg bg-white shadow-sm border border-slate-200"></div>
                <p class="font-medium text-sm">White / Background</p>
                <code class="text-xs text-slate-500">bg-white</code>
            </div>
            <div class="space-y-2">
                <div class="h-24 w-full rounded-lg bg-slate-50 shadow-sm border border-slate-200"></div>
                <p class="font-medium text-sm">Slate 50 / Surface</p>
                <code class="text-xs text-slate-500">bg-slate-50</code>
            </div>
        </div>
    </section>

    <!-- 2. Typography -->
    <section class="mb-16">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">2. Typografie</h2>
        <div class="space-y-6 bg-white p-8 rounded-xl border border-slate-200 shadow-sm">
            <div>
                <span class="text-xs text-slate-400 uppercase font-bold tracking-widest">Heading 1</span>
                <h1 class="text-4xl font-extrabold text-slate-900">The quick brown fox jumps over the lazy dog.</h1>
            </div>
            <div>
                <span class="text-xs text-slate-400 uppercase font-bold tracking-widest">Heading 2</span>
                <h2 class="text-2xl font-bold text-slate-900">The quick brown fox jumps over the lazy dog.</h2>
            </div>
            <div>
                <span class="text-xs text-slate-400 uppercase font-bold tracking-widest">Body Text</span>
                <p class="text-base text-slate-500">
                    Lorem ipsum dolor sit amet, consectetur adipiscing elit. Nulla convallis egestas rhoncus.
                    Donec facilisis fermentum sem, ac viverra ante luctus vel.
                </p>
            </div>
            <div>
                <span class="text-xs text-slate-400 uppercase font-bold tracking-widest">Small Text</span>
                <p class="text-sm text-slate-400">Copyright © 2026 TicketsPlease - Alle Rechte vorbehalten.</p>
            </div>
        </div>
    </section>

    <!-- 3. Buttons -->
    <section class="mb-16">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">3. Buttons & Actions</h2>
        <div class="p-8 bg-white rounded-xl border border-slate-200 shadow-sm space-y-8">
            <div class="flex flex-wrap items-center gap-4">
                <a href="#" class="inline-flex items-center px-8 py-3 text-base font-medium text-white border border-transparent rounded-md bg-brand-primary hover:bg-brand-secondary transition ease-in-out duration-150 shadow-sm">
                    Primary Button
                </a>
                <a href="#" class="inline-flex items-center px-8 py-3 text-base font-medium border border-transparent rounded-md text-brand-primary bg-white hover:bg-slate-50 shadow-sm transition ease-in-out duration-150">
                    Secondary Button
                </a>
                <button class="text-slate-500 hover:text-brand-primary transition duration-150 underline decoration-slate-300 underline-offset-4">
                    Text Link/Button
                </button>
            </div>
            <div class="flex flex-wrap items-center gap-4">
                <button class="inline-flex items-center justify-center w-12 h-12 text-white rounded-md bg-brand-primary hover:bg-brand-secondary">
                    <i class="fa-solid fa-plus"></i>
                </button>
                <button class="inline-flex items-center justify-center w-12 h-12 border border-slate-200 rounded-md text-slate-500 hover:bg-slate-50">
                    <i class="fa-solid fa-trash"></i>
                </button>
                <button class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-primary text-white font-bold">
                    JD
                </button>
            </div>
        </div>
    </section>

    <!-- 4. Cards & Information -->
    <section class="mb-16">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">4. Cards & Information</h2>
        <div class="grid md:grid-cols-2 gap-8">
            <!-- Feature Card Example -->
            <div class="relative bg-white p-8 rounded-xl border border-slate-200 shadow-sm hover:shadow-md transition duration-150">
                 <dt>
                    <div class="absolute flex items-center justify-center w-12 h-12 text-white rounded-md bg-brand-primary">
                        <i class="fa-solid fa-layer-group"></i>
                    </div>
                    <p class="ml-16 text-lg font-medium leading-6 text-slate-900">Standard Feature Card</p>
                </dt>
                <dd class="mt-2 ml-16 text-base text-slate-500">
                    Das ist eine beispielhafte Beschreibung für ein Feature oder eine Information in einer Card.
                </dd>
            </div>

            <!-- Dashboard Stat Card -->
            <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-slate-500">Offene Tickets</p>
                    <p class="text-3xl font-extrabold text-slate-900">24</p>
                </div>
                <div class="w-12 h-12 rounded-full bg-slate-50 flex items-center justify-center text-brand-primary">
                    <i class="fa-solid fa-ticket text-xl"></i>
                </div>
            </div>
        </div>
    </section>

    <!-- 5. Forms (Preview) -->
    <section class="mb-16">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">5. Formulare & Inputs</h2>
        <div class="bg-white p-8 rounded-xl border border-slate-200 shadow-sm max-w-2xl">
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Standard Input</label>
                    <input type="text" class="w-full px-4 py-2 border border-slate-200 rounded-md focus:ring-2 focus:ring-brand-primary focus:border-transparent outline-none transition duration-150" placeholder="Text eingeben...">
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Disabled Input</label>
                    <input type="text" disabled class="w-full px-4 py-2 border border-slate-100 bg-slate-50 rounded-md text-slate-400 cursor-not-allowed" value="Nicht änderbar">
                </div>
            </div>
        </div>
    </section>

    <!-- 6. Feedback & Indicators -->
    <section class="mb-16">
        <h2 class="text-2xl font-bold text-slate-900 mb-6">6. Feedback & Hinweise</h2>
        <div class="p-8 bg-white rounded-xl border border-slate-200 shadow-sm space-y-8">
            <!-- Badges -->
            <div class="flex flex-wrap gap-4">
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-slate-100 text-slate-800">
                    Draft
                </span>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                    Active
                </span>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                    In Progress
                </span>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-brand-primary/10 text-brand-primary">
                    Custom Brand
                </span>
            </div>

            <!-- Alerts -->
            <div class="space-y-4 max-w-3xl">
                <div class="rounded-md bg-blue-50 p-4 border-l-4 border-blue-400">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <i class="fa-solid fa-circle-info text-blue-400"></i>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-blue-700">
                                Ein informativer Hinweis für den Benutzer.
                            </p>
                        </div>
                    </div>
                </div>
                <div class="rounded-md bg-green-50 p-4 border-l-4 border-green-400">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <i class="fa-solid fa-circle-check text-green-400"></i>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-green-700">
                                Erfolgsmeldung: Die Daten wurden gespeichert.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
