@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
<style>
    .active-glow:active { box-shadow: 0 0 25px oklch(0.55 0.22 260 / 0.4); }
    .glass { background: oklch(1 0 0 / 0.03); backdrop-filter: blur(12px); border: 1px solid oklch(1 0 0 / 0.1); }

    /* Premium Slider Styling */
    input[type="range"].slider-glow::-webkit-slider-thumb {
        -webkit-appearance: none;
        height: 18px;
        width: 18px;
        border-radius: 50%;
        background: oklch(0.55 0.22 260);
        box-shadow: 0 0 10px oklch(0.55 0.22 260 / 0.5);
        cursor: pointer;
        border: 2px solid white;
        transition: all 0.2s ease;
    }
    input[type="range"].slider-glow::-webkit-slider-thumb:hover {
        transform: scale(1.2);
        box-shadow: 0 0 15px oklch(0.55 0.22 260 / 0.8);
    }
    input[type="range"].slider-glow::-moz-range-thumb {
        height: 18px;
        width: 18px;
        border-radius: 50%;
        background: oklch(0.55 0.22 260);
        box-shadow: 0 0 10px oklch(0.55 0.22 260 / 0.5);
        cursor: pointer;
        border: 2px solid white;
        transition: all 0.2s ease;
    }
    input[type="range"].slider-glow::-moz-range-thumb:hover {
        transform: scale(1.2);
        box-shadow: 0 0 15px oklch(0.55 0.22 260 / 0.8);
    }
    input[type="range"].slider-glow {
        margin: 0;
        background: transparent;
    }
    /* Webkit track styles for Glow variant */
    input[type="range"].slider-glow::-webkit-slider-runnable-track {
        height: 4px;
        background: oklch(0.55 0.22 260 / 0.2);
        border-radius: 99px;
    }
    /* Moz track styles */
    input[type="range"].slider-glow::-moz-range-track {
        height: 4px;
        background: oklch(0.55 0.22 260 / 0.2);
        border-radius: 99px;
    }

    /* Destructive Danger Button Polish */
    .btn-danger-premium {
        background: oklch(0.6 0.25 25);
        color: white;
        border: 1px solid oklch(0.4 0.2 25);
        box-shadow: 0 0 15px oklch(0.6 0.25 25 / 0.3);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-weight: 800;
    }
    .btn-danger-premium:hover {
        background: oklch(0.5 0.25 25);
        box-shadow: 0 0 25px oklch(0.6 0.25 25 / 0.6);
        transform: translateY(-2px);
        animation: destructive-pulse 1.5s infinite;
    }
    @@keyframes destructive-pulse {
        0% { box-shadow: 0 0 15px oklch(0.6 0.25 25 / 0.4); }
        50% { box-shadow: 0 0 35px oklch(0.6 0.25 25 / 0.8); }
        100% { box-shadow: 0 0 15px oklch(0.6 0.25 25 / 0.4); }
    }

    /* Standardized Fallback Styles (Ensure visibility in Styleguide) */
    .btn-secondary { background-color: oklch(0.45 0.05 260); color: white; display: inline-flex; align-items: center; justify-content: center; border-radius: 0.75rem; font-weight: 600; transition: all 0.3s; }
    .btn-secondary:hover { transform: translateY(-2px); box-shadow: 0 4px 12px oklch(0.1 0.01 260 / 0.1); background-color: oklch(0.4 0.05 260); }
    
    .btn-secondary-outline { border: 2px solid oklch(0.45 0.05 260); color: oklch(0.45 0.05 260); display: inline-flex; align-items: center; justify-content: center; border-radius: 0.75rem; font-weight: 600; transition: all 0.3s; }
    .btn-secondary-outline:hover { background-color: oklch(0.45 0.05 260); color: white; transform: translateY(-2px); }

    .btn-danger { background-color: oklch(0.55 0.22 25); color: white; display: inline-flex; align-items: center; justify-content: center; border-radius: 0.75rem; font-weight: 600; transition: all 0.3s; }
    .btn-danger:hover { transform: translateY(-2px); box-shadow: 0 4px 15px oklch(0.55 0.22 25 / 0.4); filter: saturate(1.5); }

    .btn-success { background-color: oklch(0.55 0.18 155); color: white; display: inline-flex; align-items: center; justify-content: center; border-radius: 0.75rem; font-weight: 600; transition: all 0.3s; }
    .btn-success:hover { transform: translateY(-2px); box-shadow: 0 4px 15px oklch(0.55 0.18 155 / 0.4); filter: saturate(1.5); }
</style>

<div class="px-4 py-12 mx-auto max-w-7xl sm:px-6 lg:px-8 animate-in fade-in">
    <!-- Header Section -->
    <header class="mb-16 border-b border-border-default dark:border-dark-border pb-10">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
            <div class="max-w-2xl">
                <span class="badge-primary mb-4 p-2 px-3 text-xs uppercase tracking-widest font-bold">@Localizer["DesignSystemVersion"]</span>
                <h1 class="text-6xl font-extrabold tracking-tighter text-text-main dark:text-dark-text-main sm:text-7xl leading-tight">
                    @Localizer["UITitle"] <span class="bg-clip-text text-transparent bg-gradient-to-r from-brand-primary to-brand-accent">@Localizer["StyleguideLabel"]</span>
                </h1>
                <p class="mt-6 text-xl text-text-secondary dark:text-dark-text-secondary leading-relaxed max-w-xl">
                    @Localizer["StyleguideIntro"]
                </p>
            </div>
            <nav class="flex gap-3 pb-2" aria-label="@Localizer["QuickActions"]">
                <button type="button" class="btn-primary min-w-[140px] shadow-xl shadow-brand-primary/20" aria-label="@Localizer["DownloadAssetsDesc"]">
                    <i class="fa-solid fa-download mr-2" aria-hidden="true"></i> @Localizer["Assets"]
                </button>
                <button type="button" class="btn-ghost border border-border-muted hover:border-brand-primary/30 transition-all p-3 px-6" aria-label="@Localizer["ViewDocs"]">
                    <i class="fa-solid fa-code mr-2" aria-hidden="true"></i> @Localizer["Docs"]
                </button>
            </nav>
        </div>
    </header>

    <!-- Navigation (Floating Glassmorphism) -->
    <nav class="sticky top-6 z-40 mb-16 glass-premium p-1.5 rounded-2xl flex items-center justify-between gap-1 overflow-x-auto whitespace-nowrap scrollbar-hide border border-white/10 shadow-3xl max-w-fit mx-auto" role="navigation" aria-label="@Localizer["MainNavigation"]">
        <a href="#tokens" class="px-4 py-2 hover:bg-brand-primary/10 rounded-xl text-sm font-bold transition-all hover:scale-105 active:scale-95">@Localizer["Tokens"]</a>
        <a href="#typography" class="px-4 py-2 hover:bg-brand-primary/10 rounded-xl text-sm font-bold transition-all hover:scale-105 active:scale-95">@Localizer["Typography"]</a>
        <a href="#buttons" class="px-4 py-2 hover:bg-brand-primary/10 rounded-xl text-sm font-bold transition-all hover:scale-105 active:scale-95">@Localizer["Actions"]</a>
        <a href="#cards" class="px-4 py-2 hover:bg-brand-primary/10 rounded-xl text-sm font-bold transition-all hover:scale-105 active:scale-95">@Localizer["Cards"]</a>
        <a href="#data" class="px-4 py-2 hover:bg-brand-primary/10 rounded-xl text-sm font-bold transition-all hover:scale-105 active:scale-95">@Localizer["Data"]</a>
        <a href="#forms" class="px-4 py-2 hover:bg-brand-primary/10 rounded-xl text-sm font-bold transition-all hover:scale-105 active:scale-95">@Localizer["Forms"]</a>
        <a href="#feedback" class="px-4 py-2 hover:bg-brand-primary/10 rounded-xl text-sm font-bold transition-all hover:scale-105 active:scale-95">@Localizer["Feedback"]</a>
        <a href="#animations" class="px-5 py-2.5 bg-brand-primary text-white rounded-xl text-sm font-extrabold shadow-lg shadow-brand-primary/25 hover:rotate-1 transition-transform">@Localizer["Motion"]</a>
    </nav>

    <!-- 1. Color Tokens -->
    <section id="tokens" class="mb-24 animate-in fade-in" aria-labelledby="tokens-title">
        <div class="flex items-center gap-4 mb-10">
            <div class="h-10 w-2 bg-gradient-to-b from-brand-primary to-brand-accent rounded-full" aria-hidden="true"></div>
            <h2 id="tokens-title" class="text-3xl font-black tracking-tight uppercase">@Localizer["CoreTokens"]</h2>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 mb-12">
            <!-- Brand Colors -->
            <section class="card p-5 group hover-lift border-t-4 border-t-blue-600" aria-label="@Localizer["ColorSpec", Localizer["BrandPrimary"]]">
                <div class="h-24 min-h-[6rem] w-full rounded-lg shadow-inner mb-4" style="background-color: #2563eb;" aria-hidden="true"></div>
                <div>
                    <h3 class="font-bold text-sm uppercase tracking-wide">@Localizer["BrandPrimary"]</h3>
                    <p class="text-xs text-text-muted mb-2">@Localizer["BrandPrimaryDesc"]</p>
                    <code class="block p-2 bg-surface-soft dark:bg-dark-surface-soft rounded text-[9px] font-mono border border-border-muted overflow-x-auto whitespace-nowrap" aria-label="@Localizer["VariableLabel"]">--brand-primary</code>
                </div>
            </section>
            <section class="card p-5 group hover-lift border-t-4 border-t-amber-500" aria-label="@Localizer["ColorSpec", Localizer["BrandAccent"]]">
                <div class="h-24 min-h-[6rem] w-full rounded-lg shadow-inner mb-4" style="background-color: #f59e0b;" aria-hidden="true"></div>
                <div>
                    <h3 class="font-bold text-sm uppercase tracking-wide">@Localizer["BrandAccent"]</h3>
                    <p class="text-xs text-text-muted mb-2">@Localizer["BrandAccentDesc"]</p>
                    <code class="block p-2 bg-surface-soft dark:bg-dark-surface-soft rounded text-[9px] font-mono border border-border-muted overflow-x-auto whitespace-nowrap" aria-label="@Localizer["VariableLabel"]">--brand-accent</code>
                </div>
            </section>

            <section class="card p-5 group hover-lift border-t-4 border-t-slate-500" aria-label="@Localizer["ColorSpec", Localizer["BrandSecondary"]]">
                <div class="h-24 min-h-[6rem] w-full rounded-lg shadow-inner mb-4" style="background-color: #64748b;" aria-hidden="true"></div>
                <div>
                    <h3 class="font-bold text-sm uppercase tracking-wide">@Localizer["BrandSecondary"]</h3>
                    <p class="text-xs text-text-muted mb-2">@Localizer["BrandSecondaryDesc"]</p>
                    <code class="block p-2 bg-surface-soft dark:bg-dark-surface-soft rounded text-[9px] font-mono border border-border-muted overflow-x-auto whitespace-nowrap" aria-label="@Localizer["VariableLabel"]">--brand-secondary</code>
                </div>
            </section>

            <section class="card p-5 group hover-lift border-t-4 border-t-emerald-500" aria-label="@Localizer["ColorSpec", Localizer["Success"]]">
                <div class="h-24 min-h-[6rem] w-full rounded-lg shadow-inner mb-4" style="background-color: #10b981;" aria-hidden="true"></div>
                <div>
                    <h3 class="font-bold text-sm uppercase tracking-wide">@Localizer["Success"]</h3>
                    <p class="text-xs text-text-muted mb-2">@Localizer["SuccessDesc"]</p>
                    <code class="block p-2 bg-surface-soft dark:bg-dark-surface-soft rounded text-[9px] font-mono border border-border-muted overflow-x-auto whitespace-nowrap" aria-label="@Localizer["VariableLabel"]">--success-primary</code>
                </div>
            </section>

            <section class="card p-5 group hover-lift border-t-4 border-t-rose-500" aria-label="@Localizer["ColorSpec", Localizer["Danger"]]">
                <div class="h-24 min-h-[6rem] w-full rounded-lg shadow-inner mb-4" style="background-color: #f43f5e;" aria-hidden="true"></div>
                <div>
                    <h3 class="font-bold text-sm uppercase tracking-wide">@Localizer["Danger"]</h3>
                    <p class="text-xs text-text-muted mb-2">@Localizer["DangerDesc"]</p>
                    <code class="block p-2 bg-surface-soft dark:bg-dark-surface-soft rounded text-[9px] font-mono border border-border-muted overflow-x-auto whitespace-nowrap" aria-label="@Localizer["VariableLabel"]">--danger-primary</code>
                </div>
            </section>
        </div>

        <!-- Semantic Secondary -->
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
            <div class="flex flex-col gap-2">
                <div class="h-10 rounded-lg bg-info-primary/20 border border-info-primary/30 flex items-center justify-center">
                    <span class="text-[10px] font-bold text-info-primary uppercase tracking-tighter">@Localizer["InfoGhost"]</span>
                </div>
            </div>
            <div class="flex flex-col gap-2">
                <div class="h-10 rounded-lg bg-warning-primary/20 border border-warning-primary/30 flex items-center justify-center">
                    <span class="text-[10px] font-bold text-warning-primary uppercase tracking-tighter">@Localizer["WarnGhost"]</span>
                </div>
            </div>
            <div class="flex flex-col gap-2">
                <div class="h-10 rounded-lg bg-surface-deep border border-border-muted flex items-center justify-center">
                    <span class="text-[10px] font-bold text-text-muted uppercase tracking-tighter">@Localizer["SurfaceDeep"]</span>
                </div>
            </div>
            <div class="flex flex-col gap-2">
                <div class="h-10 rounded-lg bg-slate-900 border border-white/5 flex items-center justify-center">
                    <span class="text-[10px] font-bold text-slate-400 uppercase tracking-tighter">@Localizer["DarkDeep"]</span>
                </div>
            </div>
            <div class="flex flex-col gap-2">
                <div class="h-10 rounded-lg bg-white dark:bg-dark-surface-main border-2 border-brand-primary/40 flex items-center justify-center shadow-lg shadow-brand-primary/5">
                    <span class="text-[10px] font-bold text-brand-primary uppercase tracking-tighter">@Localizer["Elevation1"]</span>
                </div>
            </div>
        </div>
    </section>

    <!-- 2. Typography -->
    <section id="typography" class="mb-24 reveal-up" aria-labelledby="typography-title">
        <div class="flex items-center gap-4 mb-10">
            <div class="h-10 w-2 bg-brand-accent rounded-full" aria-hidden="true"></div>
            <h2 id="typography-title" class="text-3xl font-black tracking-tight uppercase">@Localizer["Typography"]</h2>
        </div>

        <div class="card p-12 space-y-16 overflow-hidden relative border border-border-muted/50">
            <div class="absolute -top-24 -right-24 w-96 h-96 bg-brand-primary/5 rounded-full blur-[120px]" aria-hidden="true"></div>

            <div class="grid lg:grid-cols-12 gap-10 items-center">
                <div class="lg:col-span-4 border-r border-border-muted pr-8">
                    <span class="text-[10px] font-black uppercase tracking-[0.3em] text-brand-primary mb-2 block">@Localizer["DisplayFontHeading"]</span>
                    <h1 class="text-7xl font-black tracking-tighter leading-none italic">@Localizer["AzureSample"]</h1>
                </div>
                <div class="lg:col-span-8">
                    <p class="text-2xl text-text-main dark:text-dark-text-main font-light leading-snug">
                        @Localizer["TypographyDisplayIntro"]
                    </p>
                </div>
            </div>

            <div class="grid lg:grid-cols-12 gap-10 pt-10 border-t border-border-muted/30">
                <div class="lg:col-span-4 space-y-8 border-r border-border-muted pr-8">
                    <div>
                        <span class="text-[10px] font-bold uppercase tracking-widest text-text-muted mb-2 block">@Localizer["HeadlineH2"]</span>
                        <h2 class="text-4xl font-extrabold tracking-tight">@Localizer["SystemCore"]</h2>
                    </div>
                    <div>
                        <span class="text-[10px] font-bold uppercase tracking-widest text-text-muted mb-2 block">@Localizer["SubHeadlineH3"]</span>
                        <h3 class="text-2xl font-bold">@Localizer["ComponentSpecs"]</h3>
                    </div>
                </div>
                <div class="lg:col-span-8 space-y-6 flex flex-col justify-center">
                    <div>
                        <span class="text-[10px] font-bold uppercase tracking-widest text-text-muted mb-3 block">@Localizer["BodyTextFont"]</span>
                        <p class="text-lg text-text-main dark:text-dark-text-main leading-relaxed">
                            @Localizer["TypographyBodyIntro"]
                        </p>
                    </div>
                    <div>
                        <span class="text-[10px] font-bold uppercase tracking-widest text-text-muted mb-2 block">@Localizer["MetadataCaptions"]</span>
                        <p class="text-sm text-text-secondary dark:text-dark-text-secondary font-medium italic">
                            @Localizer["MetadataCaptionsDesc"]
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 3. Actions & Buttons -->
    <section id="buttons" class="mb-24 reveal-up" aria-labelledby="buttons-title">
        <div class="flex items-center gap-4 mb-10">
            <div class="h-10 w-2 bg-success-primary rounded-full" aria-hidden="true"></div>
            <h2 id="buttons-title" class="text-3xl font-black tracking-tight uppercase">@Localizer["ActionsComponents"]</h2>
        </div>

        <div class="grid lg:grid-cols-2 gap-10">
            <!-- Variations -->
            <div class="card p-10 flex flex-col">
                <h3 class="text-sm font-black uppercase tracking-widest text-text-muted mb-8 border-l-4 border-brand-primary pl-4">@Localizer["StandardVariations"]</h3>
                <div class="grid grid-cols-2 gap-4">
                    <button type="button" class="btn-primary min-w-[160px] py-4">@Localizer["PrimarySolid"]</button>
                    <button type="button" class="btn-accent min-w-[160px] py-4">@Localizer["AccentSolid"]</button>
                    <button type="button" class="btn-secondary min-w-[160px] py-4">@Localizer["SecondarySolid"]</button>
                    <button type="button" class="btn-secondary-outline min-w-[160px] py-4">@Localizer["SecondaryOutline"]</button>
                    <button type="button" class="btn-ghost border border-border-muted min-w-[160px] py-4">@Localizer["GhostDefault"]</button>
                    <button type="button" class="btn-danger min-w-[160px] py-4">@Localizer["DangerSolid"]</button>
                    <button type="button" class="btn-success min-w-[160px] py-4">@Localizer["SuccessSolid"]</button>
                </div>

                <h3 class="text-sm font-black uppercase tracking-widest text-text-muted mt-12 mb-8 border-l-4 border-brand-primary pl-4">@Localizer["PremiumEffects"]</h3>
                <div class="flex flex-wrap gap-4">
                    <button type="button" class="btn-primary px-8 py-4 shadow-xl shadow-brand-primary/25 hover:shadow-brand-primary/40 transition-all hover:-translate-y-1 active:scale-95">
                        @Localizer["OuterGlow"]
                    </button>
                    <button type="button" class="glass-premium px-8 py-4 rounded-xl font-bold border border-brand-primary/20 hover:bg-white/10 transition-all active:scale-95 text-brand-primary">
                        @Localizer["GlassEffect"]
                    </button>
                </div>
            </div>

            <!-- Sizes & Icons -->
            <div class="card p-10 flex flex-col">
                <h3 class="text-sm font-black uppercase tracking-widest text-text-muted mb-8 border-l-4 border-success-primary pl-4">@Localizer["StatesFeedback"]</h3>
                <div class="flex flex-wrap items-center gap-4 mb-10">
                    <button type="button" class="btn-primary flex items-center gap-3 px-6 py-3 cursor-wait opacity-80" aria-busy="true">
                        <i class="fa-solid fa-circle-notch animate-spin" aria-hidden="true"></i> @Localizer["Loading"]...
                    </button>
                    <button type="button" class="btn-primary px-6 py-3 grayscale cursor-not-allowed opacity-50" disabled>
                        @Localizer["Disabled"]
                    </button>
                </div>

                <h3 class="text-sm font-black uppercase tracking-widest text-text-muted mb-8 border-l-4 border-success-primary pl-4">@Localizer["SizeHierarchy"]</h3>
                <div class="flex flex-wrap items-end gap-5">
                    <button type="button" class="btn-primary text-xs px-4 py-2" aria-label="@Localizer["SmallButton"]">@Localizer["Small"]</button>
                    <button type="button" class="btn-primary text-base px-6 py-3" aria-label="@Localizer["MediumButton"]">@Localizer["Medium"]</button>
                    <button type="button" class="btn-primary text-lg px-8 py-4 font-black" aria-label="@Localizer["LargePremiumButton"]">@Localizer["LargePremium"]</button>
                </div>

                <h3 class="text-sm font-black uppercase tracking-widest text-text-muted mt-12 mb-8 border-l-4 border-success-primary pl-4">@Localizer["IconIntegration"]</h3>
                <div class="flex flex-wrap gap-4">
                    <button type="button" class="btn-icon h-12 w-12 bg-surface-soft hover:bg-brand-primary hover:text-white border border-border-muted transition-all" aria-label="@Localizer["AddItem"]">
                        <i class="fa-solid fa-plus text-lg" aria-hidden="true"></i>
                    </button>
                    <button type="button" class="btn-icon h-12 w-12 glass-premium border border-white/10 hover:border-brand-primary transition-all text-brand-primary" aria-label="@Localizer["Notifications"]">
                        <i class="fa-solid fa-bell" aria-hidden="true"></i>
                    </button>
                    <button type="button" class="btn-ghost flex items-center group font-bold px-6 py-3">
                        @Localizer["Continue"] <i class="fa-solid fa-arrow-right ml-3 group-hover:translate-x-2 transition-transform" aria-hidden="true"></i>
                    </button>
                </div>
            </div>
        </div>
    </section>

    <!-- 4. Data Display (Cards & Badges) -->
    <section id="cards" class="mb-24 reveal-up" aria-labelledby="cards-title">
        <div class="flex items-center gap-4 mb-10">
            <div class="h-10 w-2 bg-info-primary rounded-full" aria-hidden="true"></div>
            <h2 id="cards-title" class="text-3xl font-black tracking-tight uppercase">@Localizer["InformationData"]</h2>
        </div>

        <div class="grid lg:grid-cols-3 gap-8 mb-8">
            <!-- Glassmorphism Card -->
            <section class="glass-premium p-8 rounded-2xl border border-white/10 hover:border-brand-primary/30 transition-all group hover-lift relative overflow-hidden" aria-label="@Localizer["GlassVariant"]">
                <div class="absolute -right-8 -bottom-8 w-32 h-32 bg-brand-primary/10 rounded-full blur-2xl group-hover:bg-brand-primary/20 transition-all" aria-hidden="true"></div>
                <div class="relative z-10">
                    <span class="text-[10px] font-black uppercase tracking-widest text-brand-primary mb-2 block">@Localizer["GlassVariant"]</span>
                    <h3 class="text-xl font-bold mb-3">@Localizer["PremiumGlass"]</h3>
                    <p class="text-sm text-text-secondary dark:text-dark-text-secondary leading-relaxed">
                        @Localizer["GlassVariantDesc"]
                    </p>
                </div>
            </section>

            <!-- Inner Glow Card -->
            <section class="card p-8 group hover:shadow-[inset_0_0_20px_rgba(59,130,246,0.1)] transition-all hover:border-brand-primary/40" aria-label="@Localizer["InteractiveVariant"]">
                <div class="w-12 h-12 rounded-xl bg-brand-accent/10 text-brand-accent flex items-center justify-center mb-6 group-hover:rotate-12 transition-transform" aria-hidden="true">
                    <i class="fa-solid fa-wand-magic-sparkles text-xl"></i>
                </div>
                <span class="text-[10px] font-black uppercase tracking-widest text-brand-accent mb-2 block">@Localizer["InteractiveVariant"]</span>
                <h3 class="text-xl font-bold mb-3">@Localizer["InnerGlow"]</h3>
                <p class="text-sm text-text-secondary dark:text-dark-text-secondary">
                    @Localizer["InnerGlowDesc"]
                </p>
            </section>

            <!-- Kanban Card (Refined) -->
            <article class="kanban-card p-6 border-l-4 border-l-brand-primary group hover:bg-surface-soft dark:hover:bg-dark-surface-soft transition-colors" aria-label="@Localizer["TicketPreview"]">
                <div class="flex gap-2 mb-4 justify-between items-start">
                    <span class="badge-success px-2 py-0.5 text-[10px]">@Localizer["Active"]</span>
                    <span class="text-[10px] text-text-muted font-mono bg-surface-soft px-2 py-1 rounded border border-border-muted/30">TKT-2048</span>
                </div>
                <h4 class="font-bold text-base mb-4 group-hover:text-brand-primary transition-colors">@Localizer["SampleTaskTitle"]</h4>
                <div class="flex items-center justify-between">
                    <div class="flex -space-x-2" aria-label="@Localizer["AssignedUsers"]">
