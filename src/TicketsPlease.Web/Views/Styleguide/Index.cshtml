    <!-- Final Lint Fixes: Dynamic ID Association -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.form-label').forEach((label, index) => {
                const nextEl = label.nextElementSibling;
                const input = nextEl?.querySelector('input, select, textarea') || (nextEl?.tagName === 'INPUT' ? nextEl : null);
                if (input) {
                    const id = input.id || `sg-auto-id-${index}`;
                    input.id = id;
                    label.setAttribute('for', id);
                }
            });
        });
    </script>
