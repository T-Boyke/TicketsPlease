@using TicketsPlease.Application.Common.Dtos
@model OrganizationDto
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer L
@{
    ViewData["Title"] = L["Workspace Sovereignty"];
}

<div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <header class="mb-12 flex justify-between items-end">
        <div>
            <div class="flex items-center gap-3 mb-4">
                 <span class="px-4 py-1.5 bg-brand-primary text-white text-[10px] font-black uppercase tracking-widest rounded-full shadow-lg shadow-brand-primary/20">@L["Product Owner Panel"]</span>
                 <span class="h-1 w-1 rounded-full bg-slate-300"></span>
                 <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">@Model.Name</span>
            </div>
            <h1 class="text-5xl font-black text-slate-900 tracking-tight">@L["Workspace Sovereignty"]</h1>
            <p class="mt-3 text-lg text-slate-500 max-w-2xl">@L["Manage your organization's personnel, service standards, and secure onboarding flow."]</p>
        </div>
        <div class="pb-2">
            <a asp-action="GovernanceLog" class="px-6 py-3 bg-slate-900 text-white rounded-2xl font-black text-xs uppercase tracking-widest hover:bg-black transition-all flex items-center gap-3 shadow-xl" aria-label="@L["View Governance Protocol"]">
                <i class="fa-solid fa-shield-halved"></i>
                @L["Governance Protocol"]
            </a>
        </div>
    </header>

    @if (TempData["StatusMessage"] != null)
    {
        <div class="mb-8 p-6 bg-emerald-50 border border-emerald-100 rounded-3xl flex items-center gap-4 text-emerald-700 animate-in slide-in-from-top-4">
            <i class="fa-solid fa-circle-check text-xl"></i>
            <span class="font-bold">@TempData["StatusMessage"]</span>
        </div>
    }

    <form asp-action="SaveGovernanceSettings" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="Name" />
        <input type="hidden" asp-for="SubscriptionLevel" />
        <input type="hidden" asp-for="IsActive" />

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            @* Column 1: SLA Core *@
            <div class="bg-indigo-950 rounded-[2.5rem] p-10 text-white shadow-2xl relative overflow-hidden group">
                <div class="absolute -right-12 -bottom-12 text-white/5 text-[14rem] pointer-events-none group-hover:rotate-12 transition-transform duration-1000">
                    <i class="fa-solid fa-clock-rotate-left"></i>
                </div>

                <h2 class="text-3xl font-black mb-2">@L["SLA Automation"]</h2>
                <p class="text-slate-400 font-medium mb-12">@L["Global policies enforce standards across all projects."]</p>

                <div class="space-y-8 relative z-10">
                    <div>
                        <label asp-for="SlaCheckIntervalMinutes" class="block text-[10px] font-black text-brand-primary uppercase tracking-widest mb-3">@L["Check Interval (Minutes)"]</label>
                        <input asp-for="SlaCheckIntervalMinutes" type="number" min="1" max="1440" 
                               class="w-full bg-white/10 border-2 border-white/10 rounded-2xl px-6 py-4 outline-none focus:border-brand-primary transition-all font-black text-2xl text-white" aria-describedby="interval-desc" />
                        <p id="interval-desc" class="mt-2 text-[10px] text-slate-500 font-bold uppercase">@L["Background service frequency."]</p>
                    </div>

                    <div>
                        <label asp-for="TimeZoneId" class="block text-[10px] font-black text-brand-primary uppercase tracking-widest mb-3">@L["Reference Timezone"]</label>
                        <select asp-for="TimeZoneId" class="w-full bg-white/10 border-2 border-white/10 rounded-2xl px-6 py-4 outline-none focus:border-brand-primary transition-all font-bold text-white appearance-none" aria-label="@L["Select Timezone"]">
                            <option value="UTC">UTC (Universal Coordinated Time)</option>
                            <option value="W. Europe Standard Time">W. Europe (Amsterdam, Berlin, Paris)</option>
                            <option value="GMT Standard Time">GMT (London, Lisbon)</option>
                            <option value="Eastern Standard Time">EST (New York, Toronto)</option>
                        </select>
                    </div>
                </div>
            </div>

            @* Column 2: Quiet Hours *@
            <div class="bg-white rounded-[2.5rem] p-10 border border-slate-100 shadow-2xl relative overflow-hidden group">
                <div class="absolute -right-8 -top-8 text-slate-500/5 text-9xl group-hover:scale-110 transition-transform duration-700">
                    <i class="fa-solid fa-moon"></i>
                </div>
                
                <h2 class="text-3xl font-black text-slate-900 mb-2">@L["Quiet Hours"]</h2>
                <p class="text-slate-500 font-medium mb-12">@L["Suppress automated notifications during these periods."]</p>

                <div class="space-y-8">
                    <div>
                        <label asp-for="QuietHoursStart" class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3">@L["Start Suppression"]</label>
                        <input asp-for="QuietHoursStart" type="time" 
                               class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl px-6 py-4 outline-none focus:border-brand-primary focus:bg-white transition-all font-black text-xl text-slate-900" aria-label="@L["Start time for quiet hours"]" />
                    </div>

                    <div>
                        <label asp-for="QuietHoursEnd" class="block text-[10px] font-black text-slate-400 uppercase tracking-widest mb-3">@L["End Suppression"]</label>
                        <input asp-for="QuietHoursEnd" type="time" 
                               class="w-full bg-slate-50 border-2 border-slate-100 rounded-2xl px-6 py-4 outline-none focus:border-brand-primary focus:bg-white transition-all font-black text-xl text-slate-900" aria-label="@L["End time for quiet hours"]" />
                    </div>

                    <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100">
                        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-2">@L["Subscription Context"]</p>
                        <div class="flex items-center justify-between">
                            <span class="font-black text-slate-900">@Model.SubscriptionLevel</span>
                            <span class="px-3 py-1 bg-emerald-500 text-white text-[10px] font-black rounded-lg">PRO</span>
                        </div>
                    </div>
                </div>
            </div>

            @* Column 3: Notifications *@
            <div class="bg-slate-50 rounded-[2.5rem] p-10 border border-slate-200 shadow-inner">
                <h2 class="text-3xl font-black text-slate-900 mb-2">@L["Alarm Filters"]</h2>
                <p class="text-slate-500 font-medium mb-12">@L["Choose which priority levels trigger global alerts."]</p>

                <div class="space-y-3">
                    <label class="flex items-center justify-between p-5 bg-white rounded-2xl border border-slate-200 cursor-pointer hover:border-brand-primary transition-all group">
                        <div class="flex items-center gap-4">
                            <div class="w-2 h-2 rounded-full bg-slate-300"></div>
                            <span class="font-bold text-slate-700">@L["Low Priority"]</span>
                        </div>
                        <input type="checkbox" asp-for="NotifyOnLow" class="w-6 h-6 rounded-lg border-2 border-slate-200 text-brand-primary focus:ring-brand-primary" aria-label="@L["Notify on low priority SLA breach"]" />
                    </label>

                    <label class="flex items-center justify-between p-5 bg-white rounded-2xl border border-slate-200 cursor-pointer hover:border-brand-primary transition-all group">
                        <div class="flex items-center gap-4">
                            <div class="w-2 h-2 rounded-full bg-blue-500"></div>
                            <span class="font-bold text-slate-700">@L["Medium Priority"]</span>
                        </div>
                        <input type="checkbox" asp-for="NotifyOnMedium" class="w-6 h-6 rounded-lg border-2 border-slate-200 text-brand-primary focus:ring-brand-primary" aria-label="@L["Notify on medium priority SLA breach"]" />
                    </label>

                    <label class="flex items-center justify-between p-5 bg-white rounded-2xl border border-slate-200 cursor-pointer hover:border-brand-primary transition-all group">
                        <div class="flex items-center gap-4">
                            <div class="w-2 h-2 rounded-full bg-orange-500"></div>
                            <span class="font-bold text-slate-700">@L["High Priority"]</span>
                        </div>
                        <input type="checkbox" asp-for="NotifyOnHigh" class="w-6 h-6 rounded-lg border-2 border-slate-200 text-brand-primary focus:ring-brand-primary" aria-label="@L["Notify on high priority SLA breach"]" />
                    </label>

                    <label class="flex items-center justify-between p-5 bg-white rounded-2xl border border-slate-200 cursor-pointer hover:border-brand-primary transition-all group">
                        <div class="flex items-center gap-4">
                            <div class="w-2 h-2 rounded-full bg-rose-500 animate-pulse"></div>
                            <span class="font-bold text-slate-700">@L["Blocker / Critical"]</span>
                        </div>
                        <input type="checkbox" asp-for="NotifyOnBlocker" class="w-6 h-6 rounded-lg border-2 border-slate-200 text-brand-primary focus:ring-brand-primary" aria-label="@L["Notify on critical SLA breach"]" />
                    </label>
                </div>

                <div class="mt-8">
                    <button type="submit" class="w-full py-5 bg-brand-primary text-white rounded-2xl font-black text-lg shadow-2xl shadow-brand-primary/40 hover:scale-[1.02] active:scale-95 transition-all">
                        @L["Commit Sovereignty Update"]
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>
