@using TicketsPlease.Application.Common.Dtos
@model List<AuditLogDto>
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer L
@{
    ViewData["Title"] = L["Governance Protocol"];
}

<div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <header class="mb-12">
        <div class="flex items-center gap-3 mb-4">
             <span class="px-4 py-1.5 bg-slate-900 text-white text-[10px] font-black uppercase tracking-widest rounded-full shadow-lg">@L["Security & Compliance"]</span>
        </div>
        <h1 class="text-5xl font-black text-slate-900 tracking-tight">@L["Governance Protocol"]</h1>
        <p class="mt-3 text-lg text-slate-500 max-w-2xl">@L["A transparent, immutable audit log of all administrative actions and policy changes within the workspace."]</p>
    </header>

    <div class="bg-white rounded-[2.5rem] border border-slate-100 shadow-2xl overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-100">
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">@L["Timestamp (UTC)"]</th>
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">@L["Actor"]</th>
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">@L["Action"]</th>
                        <th class="px-8 py-6 text-[10px] font-black text-slate-400 uppercase tracking-widest">@L["Details"]</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @if (Model.Any())
                    {
                        foreach (var log in Model)
                        {
                            <tr class="hover:bg-slate-50/50 transition-colors">
                                <td class="px-8 py-6 whitespace-nowrap">
                                    <span class="font-mono text-sm text-slate-500">@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</span>
                                </td>
                                <td class="px-8 py-6">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full bg-brand-primary/10 flex items-center justify-center text-brand-primary font-black text-xs">
                                            @log.ActorUserName.Substring(0, Math.Min(2, log.ActorUserName.Length)).ToUpper()
                                        </div>
                                        <span class="font-bold text-slate-900">@log.ActorUserName</span>
                                    </div>
                                </td>
                                <td class="px-8 py-6">
                                    <span class="px-3 py-1 bg-slate-100 text-slate-600 rounded-lg text-xs font-black uppercase tracking-tight">@log.ActionType</span>
                                </td>
                                <td class="px-8 py-6">
                                    <p class="text-sm text-slate-600 font-medium leading-relaxed">@log.Description</p>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="px-8 py-20 text-center">
                                <div class="flex flex-col items-center gap-4">
                                    <i class="fa-solid fa-clipboard-list text-6xl text-slate-100"></i>
                                    <p class="text-slate-400 font-bold uppercase tracking-widest text-xs">@L["No entries found in protocol"]</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="mt-12 flex justify-between items-center">
        <a asp-action="Settings" class="px-8 py-4 bg-slate-100 hover:bg-slate-200 text-slate-900 rounded-2xl font-black transition-all flex items-center gap-3" aria-label="@L["Go back to Workspace Sovereignty"]">
            <i class="fa-solid fa-arrow-left"></i>
            @L["Back to Sovereignty"]
        </a>
        <p class="text-xs text-slate-400 font-bold uppercase tracking-widest">@L["Generated by Enterprise Governance Engine v4.0"]</p>
    </div>
</div>
