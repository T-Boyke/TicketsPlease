@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer L
@{
    ViewData["Title"] = L["Imprint"];
}

<main role="main" class="min-h-screen bg-surface-subtle py-16 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto reveal-up">
        @* Header Section *@
        <header class="mb-12 text-center">
            <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-slate-900 mb-4 bg-linear-to-r from-brand-primary to-brand-accent bg-clip-text text-transparent">
                @L["Imprint"]
            </h1>
            <div class="mt-6 flex justify-center gap-4 no-print">
                <button onclick="window.print()" class="btn btn-ghost flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
                    <span>Print PDF</span>
                </button>
            </div>
        </header>

        <div class="grid md:grid-cols-2 gap-8">
            <section class="glass-premium p-8 md:p-10 accent-border" aria-labelledby="section-tmg">
                <h2 id="section-tmg" class="text-xl font-bold text-slate-900 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                    @L["Information according to § 5 TMG"]
                </h2>
                <address class="not-italic text-slate-600 leading-relaxed">
                    TicketsPlease Enterprise Systems<br />
                    Musterstraße 123<br />
                    12345 Musterstadt
                </address>
            </section>

            <section class="glass-premium p-8 md:p-10" aria-labelledby="section-representative">
                <h2 id="section-representative" class="text-xl font-bold text-slate-900 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    @L["Represented by"]
                </h2>
                <p class="text-slate-600 font-medium text-lg">T-Boyke</p>
            </section>

            <section class="glass-premium p-8 md:p-10" aria-labelledby="section-contact">
                <h2 id="section-contact" class="text-xl font-bold text-slate-900 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                    @L["Contact"]
                </h2>
                <div class="space-y-2 text-slate-600">
                    <p><span class="font-semibold">@L["Phone"]:</span> +49 (0) 123 456789</p>
                    <p><span class="font-semibold">@L["Email"]:</span> <a href="mailto:info@ticketsplease.com" class="text-brand-primary hover:underline">info@ticketsplease.com</a></p>
                </div>
            </section>

            <section class="glass-premium p-8 md:p-10" aria-labelledby="section-vat">
                <h2 id="section-vat" class="text-xl font-bold text-slate-900 mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-brand-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                    @L["Value Added Tax ID"]
                </h2>
                <p class="text-slate-600">
                    <span class="block text-sm mb-1 opacity-75">@L["VAT ID number according to § 27 a Value Added Tax Act"]:</span>
                    <span class="font-mono font-bold tracking-wider">DE 999 999 999</span>
                </p>
            </section>
        </div>
    </div>
</main>
