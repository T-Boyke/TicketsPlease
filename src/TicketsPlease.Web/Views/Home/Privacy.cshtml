@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer L
@{
    ViewData["Title"] = L["Privacy Policy"];
}

<div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-extrabold text-slate-900 mb-6">@L["Privacy Policy"]</h1>
    
    <div class="prose prose-slate lg:prose-lg max-w-none text-slate-600">
        <p class="lead">@L["Information about how we process your data."]</p>
        
        <h2 class="text-xl font-bold text-slate-800 mt-8 mb-4">1. @L["General Information"]</h2>
        <p>@L["We take the protection of your personal data very seriously. This application (TicketsPlease) processes data solely for project management purposes."]</p>
        
        <h2 class="text-xl font-bold text-slate-800 mt-8 mb-4">2. @L["Data Collection"]</h2>
        <p>@L["When using our ticket system, we store your username, email, and optionally your profile data. For audit reasons, we also store Geo/IP timestamps upon ticket creation (F1.6)."]</p>
        
        <h2 class="text-xl font-bold text-slate-800 mt-8 mb-4">3. @L["Soft-Delete and Data Retention"]</h2>
        <p>@L["Our system uses a soft-delete mechanism. This means that deleted records remain in the database but are hidden from the UI unless explicitly purged (ADR 0120)."]</p>
        
        <h2 class="text-xl font-bold text-slate-800 mt-8 mb-4">4. @L["Your Rights"]</h2>
        <p>@L["You have the right to information, correction, or deletion of your personal data at any time."]</p>
    </div>
</div>
