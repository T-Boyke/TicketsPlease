@using Microsoft.AspNetCore.Mvc.Localization
@using TicketsPlease.Web.Models.Account
@inject IViewLocalizer L
@model EditProfileViewModel
@{
    ViewData["Title"] = L["Edit Profile"];
}

<div class="max-w-xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <div class="bg-white shadow-2xl rounded-3xl overflow-hidden border border-slate-100 animate-in fade-in slide-in-from-bottom-4 duration-500">
        <div class="px-8 py-6 bg-slate-50 border-b border-slate-100 flex items-center justify-between">
            <h1 class="text-2xl font-black text-slate-900 tracking-tight">@L["Edit Profile"]</h1>
            <a asp-action="Profile" class="h-10 w-10 flex items-center justify-center rounded-full bg-white border border-slate-200 text-slate-400 hover:text-rose-500 hover:border-rose-100 transition-all">
                <i class="fa-solid fa-xmark"></i>
            </a>
        </div>

        <form asp-action="Edit" method="post" class="p-8 space-y-6">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-rose-500 text-sm font-bold bg-rose-50 p-4 rounded-xl border border-rose-100"></div>

            <div class="space-y-2">
                <label asp-for="Username" class="text-xs font-black text-slate-400 uppercase tracking-widest px-1">@L["Username"]</label>
                <div class="relative group">
                    <i class="fa-solid fa-user absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-brand-primary transition-colors"></i>
                    <input asp-for="Username" class="w-full pl-11 pr-4 py-3 bg-slate-50 border-none rounded-2xl focus:ring-4 focus:ring-brand-primary/10 transition-all font-bold text-slate-700" />
                </div>
                <span asp-validation-for="Username" class="text-rose-500 text-[10px] font-bold px-1"></span>
            </div>

            <div class="space-y-2">
                <label asp-for="Email" class="text-xs font-black text-slate-400 uppercase tracking-widest px-1">@L["Email"]</label>
                <div class="relative group">
                    <i class="fa-solid fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-brand-primary transition-colors"></i>
                    <input asp-for="Email" class="w-full pl-11 pr-4 py-3 bg-slate-50 border-none rounded-2xl focus:ring-4 focus:ring-brand-primary/10 transition-all font-bold text-slate-700" />
                </div>
                <span asp-validation-for="Email" class="text-rose-500 text-[10px] font-bold px-1"></span>
            </div>

            <div class="pt-4 border-t border-slate-100 space-y-4">
                <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest px-1">@L["Change Password"]</h3>
                
                <div class="space-y-2">
                    <label asp-for="NewPassword" class="text-[10px] font-bold text-slate-500 px-1">@L["New Password"]</label>
                    <div class="relative group">
                        <i class="fa-solid fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-brand-primary transition-colors"></i>
                        <input asp-for="NewPassword" type="password" placeholder="••••••••" class="w-full pl-11 pr-4 py-3 bg-slate-50 border-none rounded-2xl focus:ring-4 focus:ring-brand-primary/10 transition-all font-bold text-slate-700" />
                    </div>
                </div>

                <div class="space-y-2">
                    <label asp-for="ConfirmPassword" class="text-[10px] font-bold text-slate-500 px-1">@L["Confirm Password"]</label>
                    <div class="relative group">
                        <i class="fa-solid fa-shield-check absolute left-4 top-1/2 -translate-y-1/2 text-slate-300 group-focus-within:text-brand-primary transition-colors"></i>
                        <input asp-for="ConfirmPassword" type="password" placeholder="••••••••" class="w-full pl-11 pr-4 py-3 bg-slate-50 border-none rounded-2xl focus:ring-4 focus:ring-brand-primary/10 transition-all font-bold text-slate-700" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-rose-500 text-[10px] font-bold px-1"></span>
                </div>
            </div>

            <div class="pt-6 flex gap-4">
                <button type="submit" class="flex-1 py-4 bg-brand-primary text-white rounded-2xl font-black text-sm uppercase tracking-widest hover:bg-brand-secondary hover:shadow-xl hover:shadow-brand-primary/30 transition-all duration-300 flex items-center justify-center gap-2 group">
                    <i class="fa-solid fa-floppy-disk group-hover:scale-110 transition-transform"></i>
                    @L["Save Changes"]
                </button>
                <a asp-action="Profile" class="px-8 py-4 bg-slate-100 text-slate-600 rounded-2xl font-black text-sm uppercase tracking-widest hover:bg-slate-200 transition-all flex items-center justify-center">
                    @L["Cancel"]
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
