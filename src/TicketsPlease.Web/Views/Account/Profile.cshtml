@using Microsoft.AspNetCore.Mvc.Localization
@using TicketsPlease.Domain.Entities
@inject IViewLocalizer L
@model User
@{
    ViewData["Title"] = L["Profile"];
}

<div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <div class="bg-white shadow-xl rounded-2xl overflow-hidden border border-slate-100">
        <div class="px-4 py-5 sm:px-6 bg-slate-50 border-b border-slate-200 flex justify-between items-center">
            <div>
                <h3 class="text-lg leading-6 font-bold text-slate-900">@L["User Profile"]</h3>
                <p class="mt-1 max-w-2xl text-sm text-slate-500">@L["Personal details and account information."]</p>
            </div>
            <a href="#" class="inline-flex items-center px-4 py-2 border border-brand-primary text-sm font-medium rounded-full text-brand-primary bg-white hover:bg-brand-primary hover:text-white transition-all">
                <i class="fa-solid fa-user-pen mr-2"></i>
                @L["Edit Profile"]
            </a>
        </div>
        <div class="px-4 py-5 sm:p-0">
            <dl class="sm:divide-y sm:divide-slate-200">
                <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
                    <dt class="text-sm font-medium text-slate-500">@L["Username"]</dt>
                    <dd class="mt-1 text-sm text-slate-900 sm:mt-0 sm:col-span-2">@Model.UserName</dd>
                </div>
                <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
                    <dt class="text-sm font-medium text-slate-500">@L["Email address"]</dt>
                    <dd class="mt-1 text-sm text-slate-900 sm:mt-0 sm:col-span-2">@Model.Email</dd>
                </div>
                <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
                    <dt class="text-sm font-medium text-slate-500">@L["Role"]</dt>
                    <dd class="mt-1 text-sm text-slate-900 sm:mt-0 sm:col-span-2">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-brand-primary/10 text-brand-primary">
                            @L["User"]
                        </span>
                    </dd>
                </div>
                <div class="py-4 sm:py-5 sm:grid sm:grid-cols-3 sm:gap-4 sm:px-6">
                    <dt class="text-sm font-medium text-slate-500">@L["Created At"]</dt>
                    <dd class="mt-1 text-sm text-slate-900 sm:mt-0 sm:col-span-2">@Model.CreatedAt.ToShortDateString()</dd>
                </div>
            </dl>
        </div>
    </div>
</div>
