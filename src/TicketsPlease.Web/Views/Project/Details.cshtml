@using Microsoft.AspNetCore.Mvc.Localization
@using TicketsPlease.Application.Common.Dtos
@inject IViewLocalizer L
@model ProjectDto
@{
    ViewData["Title"] = L["Project Details"];
}

<div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
    <div class="mb-10 flex items-center space-x-3">
        <a asp-action="Index" class="text-slate-400 hover:text-brand-primary transition-colors">
            <i class="fa-solid fa-arrow-left-long text-xl"></i>
        </a>
        <h1 class="text-3xl font-extrabold text-slate-900">@Model.Title</h1>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        @* Project Stats & Main Info *@
        <div class="lg:col-span-2 space-y-8">
            <div class="bg-white shadow-xl rounded-2xl p-8 border border-slate-100">
                <h2 class="text-xl font-bold text-slate-900 mb-4">@L["Overview"]</h2>
                <p class="text-slate-600 leading-relaxed">@Model.Description</p>
                
                <div class="mt-8 grid grid-cols-2 md:grid-cols-4 gap-4">
                    <div class="bg-slate-50 p-4 rounded-xl">
                        <div class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">@L["Status"]</div>
                        <div class="text-sm font-bold @(Model.IsOpen ? "text-emerald-600" : "text-slate-600")">
                            @(Model.IsOpen ? L["Active"] : L["Closed"])
                        </div>
                    </div>
                    <div class="bg-slate-50 p-4 rounded-xl">
                        <div class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">@L["Start Date"]</div>
                        <div class="text-sm font-bold text-slate-900">@Model.StartDate.ToShortDateString()</div>
                    </div>
                    <div class="bg-slate-50 p-4 rounded-xl">
                        <div class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">@L["End Date"]</div>
                        <div class="text-sm font-bold text-slate-900">@(Model.EndDate?.ToShortDateString() ?? "-")</div>
                    </div>
                </div>
            </div>

            @* Tickets for this project (F3) *@
            <div class="bg-white rounded-2xl shadow-sm border border-slate-200">
                <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center">
                    <h2 class="text-xl font-bold text-slate-900">@L["Tickets"]</h2>
                    <a asp-controller="Tickets" asp-action="Create" asp-route-projectId="@Model.Id" class="text-sm font-bold text-brand-primary hover:text-brand-secondary transition-colors">
                        <i class="fa-solid fa-plus mr-1"></i> @L["New Ticket"]
                    </a>
                </div>
                
                @{
                    var projectTickets = ViewBag.Tickets as IEnumerable<TicketDto> ?? new List<TicketDto>();
                }
                
                @if (!projectTickets.Any())
                {
                    <div class="p-8 text-center">
                        <i class="fa-solid fa-ticket-simple text-slate-300 text-4xl mb-4"></i>
                        <h3 class="text-lg font-bold text-slate-900">@L["No tickets found"]</h3>
                        <p class="text-slate-500 text-sm mt-1">@L["There are no tickets associated with this project yet."]</p>
                    </div>
                }
                else
                {
                    <div class="divide-y divide-slate-100 max-h-96 overflow-y-auto custom-scrollbar">
                        @foreach (var ticket in projectTickets)
                        {
                            <a asp-controller="Tickets" asp-action="Details" asp-route-id="@ticket.Id" class="block px-6 py-4 hover:bg-slate-50 transition-colors group">
                                <div class="flex items-start justify-between">
                                    <div>
                                        <div class="flex items-center space-x-2">
                                            <span class="text-xs font-bold text-slate-500">@ticket.Id.ToString().Substring(0, 8)</span>
                                            <h4 class="text-md font-bold text-slate-900 group-hover:text-brand-primary transition-colors">@ticket.Title</h4>
                                        </div>
                                        <div class="mt-1 flex items-center space-x-4 text-xs text-slate-500">
                                            @{
                                                var statusClass = ticket.Status switch
                                                {
                                                    "Done" => "bg-emerald-100 text-emerald-800",
                                                    "In Progress" => "bg-blue-100 text-blue-800",
                                                    _ => "bg-slate-100 text-slate-800"
                                                };
                                            }
                                            <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold @statusClass">
                                                @ticket.Status
                                            </span>
                                            @if (ticket.Priority != null)
                                            {
                                                <span class="flex items-center" style="color: @(ticket.Priority.ColorHex ?? "#f59e0b")">
                                                    <i class="fa-solid fa-fire mr-1"></i> @ticket.Priority.Name
                                                </span>
                                            }
                                        </div>
                                    </div>
                                    @if (!string.IsNullOrEmpty(ticket.AssignedUserName))
                                    {
                                        <div class="flex-shrink-0 ml-4">
                                            <div class="h-8 w-8 rounded-full bg-brand-primary/10 text-brand-primary flex items-center justify-center font-bold text-xs" title="@ticket.AssignedUserName">
                                                @(ticket.AssignedUserName.Length >= 2 ? ticket.AssignedUserName.Substring(0, 2).ToUpper() : "?")
                                            </div>
                                        </div>
                                    }
                                </div>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>

        @* Actions Sidebar *@
        <div class="space-y-6">
            <div class="bg-white shadow-xl rounded-2xl p-6 border border-slate-100">
                <h3 class="text-sm font-bold text-slate-900 uppercase tracking-widest mb-4">@L["Management Actions"]</h3>
                <div class="space-y-3">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="flex items-center w-full px-4 py-3 text-sm font-bold text-amber-600 bg-amber-50 rounded-xl hover:bg-amber-100 transition-all">
                        <i class="fa-solid fa-pen-to-square mr-3"></i> @L["Edit Configuration"]
                    </a>
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('@L["Are you sure?"]');">
                        <button type="submit" class="flex items-center w-full px-4 py-3 text-sm font-bold text-red-600 bg-red-50 rounded-xl hover:bg-red-100 transition-all">
                            <i class="fa-solid fa-trash-can mr-3"></i> @L["Archive Project"]
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
