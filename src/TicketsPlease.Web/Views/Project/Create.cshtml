@using Microsoft.AspNetCore.Mvc.Localization
@using TicketsPlease.Application.Common.Dtos
@inject IViewLocalizer L
@model CreateProjectDto
@{
    ViewData["Title"] = L["Create Project"];
}

<div class="max-w-3xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <div class="bg-white shadow-2xl shadow-slate-200 rounded-3xl overflow-hidden border border-slate-100">
        <div class="px-8 py-6 bg-slate-50 border-b border-slate-100 flex items-center justify-between">
            <h1 class="text-2xl font-extrabold text-slate-900">@L["Create New Project"]</h1>
            <a asp-action="Index" class="text-slate-400 hover:text-slate-600 transition-colors">
                <i class="fa-solid fa-xmark text-xl"></i>
            </a>
        </div>

        <form asp-action="Create" method="post" class="p-8 space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            <div>
                <label asp-for="Title" for="Title" class="block text-sm font-bold text-slate-700">@L["Project Title"]</label>
                <div class="mt-1 relative group">
                    <input asp-for="Title" id="Title" class="block w-full px-4 py-3 border border-slate-300 rounded-xl shadow-sm focus:ring-2 focus:ring-brand-primary/20 focus:border-brand-primary placeholder-slate-400 transition-all sm:text-sm" placeholder="@L["Enter project title..."]" />
                    <span asp-validation-for="Title" class="text-red-500 text-xs mt-1"></span>
                </div>
            </div>

            <div>
                <label asp-for="Description" for="Description" class="block text-sm font-bold text-slate-700">@L["Description"]</label>
                <div class="mt-1 relative group">
                    <textarea asp-for="Description" id="Description" rows="4" class="block w-full px-4 py-3 border border-slate-300 rounded-xl shadow-sm focus:ring-2 focus:ring-brand-primary/20 focus:border-brand-primary placeholder-slate-400 transition-all sm:text-sm" placeholder="@L["Optional project details..."]"></textarea>
                    <span asp-validation-for="Description" class="text-red-500 text-xs mt-1"></span>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                    <label asp-for="StartDate" for="StartDate" class="block text-sm font-bold text-slate-700">@L["Start Date"]</label>
                    <div class="mt-1">
                        <input asp-for="StartDate" id="StartDate" type="date" class="block w-full px-4 py-3 border border-slate-300 rounded-xl shadow-sm focus:ring-2 focus:ring-brand-primary/20 focus:border-brand-primary transition-all sm:text-sm" />
                        <span asp-validation-for="StartDate" class="text-red-500 text-xs mt-1"></span>
                    </div>
                </div>

                <div>
                    <label asp-for="EndDate" for="EndDate" class="block text-sm font-bold text-slate-700">@L["End Date (Optional)"]</label>
                    <div class="mt-1">
                        <input asp-for="EndDate" id="EndDate" type="date" class="block w-full px-4 py-3 border border-slate-300 rounded-xl shadow-sm focus:ring-2 focus:ring-brand-primary/20 focus:border-brand-primary transition-all sm:text-sm" />
                        <span asp-validation-for="EndDate" class="text-red-500 text-xs mt-1"></span>
                    </div>
                </div>
            </div>

            <div class="pt-6 border-t border-slate-100 flex justify-end space-x-4">
                <a asp-action="Index" class="px-6 py-3 border border-slate-300 rounded-full text-sm font-bold text-slate-600 hover:bg-slate-50 transition-all">@L["Cancel"]</a>
                <button type="submit" class="px-8 py-3 border border-transparent rounded-full shadow-lg text-sm font-bold text-white bg-brand-primary hover:bg-brand-secondary transition-all">
                    <i class="fa-solid fa-floppy-disk mr-2"></i>
                    @L["Launch Project"]
                </button>
            </div>
        </form>
    </div>
</div>
