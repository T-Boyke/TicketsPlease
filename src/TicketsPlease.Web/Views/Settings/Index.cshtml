@using Microsoft.AspNetCore.Mvc.Localization
@using TicketsPlease.Domain.Entities
@inject IViewLocalizer Localizer
@model UserProfile
@{
    ViewData["Title"] = Localizer["Title"];
}

<div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <header class="mb-12">
        <div class="flex items-center gap-2 text-xs font-black text-slate-400 uppercase tracking-widest mb-4">
            <i class="fa-solid fa-user-astronaut text-brand-primary"></i>
            <span>@Localizer["IdentityWorkspace"]</span>
            <span class="h-1 w-1 rounded-full bg-slate-300"></span>
            <span class="text-slate-900">@Localizer["ExperiencePreferences"]</span>
        </div>
        <h1 class="text-4xl font-black text-slate-900 tracking-tight">@Localizer["MainHeading"]</h1>
        <p class="mt-3 text-lg text-slate-500">@Localizer["SubHeading"]</p>
    </header>

    @if (TempData["StatusMessage"] != null)
    {
        <div class="mb-8 p-6 bg-slate-900 border border-slate-800 rounded-3xl flex items-center gap-4 text-white animate-in slide-in-from-top-4 shadow-xl">
            <div class="h-10 w-10 rounded-full bg-brand-primary/20 flex items-center justify-center text-brand-primary">
                 <i class="fa-solid fa-sparkles text-lg"></i>
            </div>
            <span class="font-bold">@TempData["StatusMessage"]</span>
        </div>
    }

    <form asp-action="Save" method="post">
        @Html.AntiForgeryToken()

        <div class="space-y-8">
            @* Performance Section *@
            <section class="bg-white rounded-[2rem] p-8 border border-slate-100 shadow-xl shadow-slate-200/40">
                <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-8 flex items-center">
                    <i class="fa-solid fa-bolt-lightning mr-2 text-amber-500"></i> @Localizer["PerformanceSectionTitle"]
                </h3>

                <div class="space-y-10">
                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                        <div class="max-w-md">
                            <label class="text-lg font-black text-slate-900 block mb-1">@Localizer["KanbanIntervalLabel"]</label>
                            <p class="text-sm text-slate-500 font-medium">@Localizer["KanbanIntervalDescription"]</p>
                        </div>
                        <div class="flex items-center gap-4">
                            <input type="range" name="kanbanUpdateIntervalMs" min="1000" max="30000" step="1000" value="@Model.KanbanUpdateIntervalMs"
                                   class="w-48 appearance-none bg-slate-100 h-2 rounded-full cursor-pointer accent-brand-primary"
                                   oninput="this.nextElementSibling.innerText = (this.value/1000) + 's'" />
                            <span class="w-12 text-center text-sm font-black text-slate-900 bg-slate-100 py-2 rounded-xl">@(Model.KanbanUpdateIntervalMs / 1000)s</span>
                        </div>
                    </div>

                    <div class="h-[1px] w-full bg-slate-50"></div>

                    <div class="flex items-center justify-between gap-6">
                        <div class="max-w-md">
                            <label class="text-lg font-black text-slate-900 block mb-1">@Localizer["ReduceAnimationsLabel"]</label>
                            <p class="text-sm text-slate-500 font-medium">@Localizer["ReduceAnimationsDescription"]</p>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" name="reduceAnimations" value="true" class="sr-only peer" @(Model.ReduceAnimations ? "checked" : "") />
                            <div class="w-14 h-8 bg-slate-100 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[4px] after:left-[4px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-6 after:w-6 after:transition-all peer-checked:bg-brand-primary"></div>
                        </label>
                    </div>
                </div>
            </section>

            @* Sensory Section *@
            <section class="bg-indigo-950 rounded-[2rem] p-8 text-slate-400 shadow-2xl relative overflow-hidden group">
                <div class="absolute -right-4 -bottom-4 text-slate-400/5 text-9xl pointer-events-none group-hover:scale-110 transition-transform duration-700">
                    <i class="fa-solid fa-volume-high"></i>
                </div>

                <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-8 flex items-center">
                    <i class="fa-solid fa-bell mr-2 text-brand-primary"></i> @Localizer["SensorySectionTitle"]
                </h3>

                <div class="space-y-10">
                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6">
                        <div class="max-w-md">
                            <label class="text-lg font-black text-slate-400 block mb-1">@Localizer["AudioSignatureLabel"]</label>
                            <p class="text-sm text-slate-400 font-medium">@Localizer["AudioSignatureDescription"]</p>
                        </div>
                        <select name="notificationSound" class="w-48 bg-white/10 border-2 border-gray-400/10 rounded-2xl px-4 py-3 outline-none focus:border-brand-primary transition-all font-bold text-white">
                            <option value="classic" selected="@(Model.NotificationSound == "classic")" class="bg-indigo-950">@Localizer["SoundClassic"]</option>
                            <option value="minimal" selected="@(Model.NotificationSound == "minimal")" class="bg-indigo-950">@Localizer["SoundMinimal"]</option>
                            <option value="vibrant" selected="@(Model.NotificationSound == "vibrant")" class="bg-indigo-950">@Localizer["SoundVibrant"]</option>
                            <option value="digital" selected="@(Model.NotificationSound == "digital")" class="bg-indigo-950">@Localizer["SoundDigital"]</option>
                        </select>
                    </div>

                    <div class="h-[1px] w-full bg-white/5"></div>

                    <div class="flex items-center justify-between gap-6">
                        <div class="max-w-md">
                            <label class="text-lg font-black text-slate-400 block mb-1">@Localizer["EmailRelaysLabel"]</label>
                            <p class="text-sm text-slate-400 font-medium">@Localizer["EmailRelaysDescription"]</p>
                        </div>
                        <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" name="emailNotificationsEnabled" value="true" class="sr-only peer" @(Model.EmailNotificationsEnabled ? "checked" : "") />
                            <div class="w-14 h-8 bg-white/10 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[4px] after:left-[4px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-6 after:w-6 after:transition-all peer-checked:bg-white/20"></div>
                        </label>
                    </div>
                </div>
            </section>
        </div>

        <div class="mt-12 flex justify-end gap-4">
            <a href="/" class="px-8 py-4 text-slate-500 font-black uppercase text-xs tracking-widest hover:text-slate-900 transition-colors">@Localizer["Cancel"]</a>
            <button type="submit" class="px-10 py-5 bg-brand-primary text-white rounded-2xl font-black text-lg shadow-xl shadow-brand-primary/20 hover:scale-105 active:scale-95 transition-all">
                @Localizer["SaveButton"]
            </button>
        </div>
    </form>
</div>
