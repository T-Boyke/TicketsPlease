@model TicketsPlease.Web.Models.NotificationsViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer L
@{
    ViewData["Title"] = L["Notifications"];
}

<div class="max-w-4xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between mb-10">
        <div>
            <h1 class="text-4xl font-black text-slate-900 tracking-tight">@L["Notifications"]</h1>
            <p class="text-slate-500 font-medium mt-2">@L["Stay updated with your latest activities and mentions."]</p>
        </div>
        <div class="flex space-x-2">
            <form asp-action="MarkAllAsRead" method="post">
                <button type="submit" class="px-4 py-2 bg-slate-100 text-slate-600 rounded-xl font-bold text-sm hover:bg-slate-200 transition-colors">
                    @L["Mark all as read"]
                </button>
            </form>
        </div>
    </div>

    <div class="bg-white rounded-[2.5rem] border border-slate-200 shadow-xl overflow-hidden">
        <div class="divide-y divide-slate-100" id="notification-list">
            <partial name="_NotificationList" model="Model" />
        </div>
    </div>
</div>

<script>
    let currentOffset = @Model.Notifications.Count;

    async function markAsRead(id) {
        try {
            const response = await fetch(`/Notifications/MarkAsRead/${id}`, {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                }
            });
            if (response.ok) {
                const element = document.getElementById(`noti-${id}`);
                const dot = document.getElementById(`dot-${id}`);
                if (element) element.classList.add('opacity-60');
                if (dot) dot.remove();
            }
        } catch (error) {
            console.error('Error marking as read:', error);
        }
    }

    async function loadMore() {
        const btn = document.getElementById('load-more-btn');
        const container = document.getElementById('load-more-container');
        if (btn) btn.disabled = true;

        try {
            const response = await fetch(`/Notifications?offset=${currentOffset}`, {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            });
            if (response.ok) {
                const html = await response.text();
                if (container) container.remove();
                document.getElementById('notification-list').insertAdjacentHTML('beforeend', html);
                currentOffset += 20;
            }
        } catch (error) {
            console.error('Error loading more:', error);
        }
    }
</script>

<style>
    body {
        background-color: #f8fafc;
    }
</style>
