@model TicketsPlease.Web.Models.NotificationsViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer L

@foreach (var notification in Model.Notifications)
{
    <div class="p-6 hover:bg-slate-50 transition-colors flex items-start gap-4 @(notification.IsRead ? "opacity-60" : "")" id="noti-@notification.Id">
        <div class="h-12 w-12 rounded-2xl bg-blue-100 flex items-center justify-center text-blue-600 flex-shrink-0">
            @if (notification.Title.Contains("ticket", StringComparison.OrdinalIgnoreCase))
            {
                <i class="fa-solid fa-ticket text-xl"></i>
            }
            else if (notification.Title.Contains("comment", StringComparison.OrdinalIgnoreCase))
            {
                <i class="fa-solid fa-comment-dots text-xl"></i>
            }
            else
            {
                <i class="fa-solid fa-bell text-xl"></i>
            }
        </div>
        <div class="flex-1">
            <div class="flex justify-between items-start">
                <h3 class="font-bold @(notification.IsRead ? "text-slate-700" : "text-slate-900")">@notification.Title</h3>
                <span class="text-[10px] font-black uppercase text-slate-400">@notification.CreatedAt.ToLocalTime().ToString("g")</span>
            </div>
            <p class="text-sm @(notification.IsRead ? "text-slate-500" : "text-slate-600") mt-1">@notification.Content</p>
            <div class="mt-3 flex space-x-4">
                @if (!string.IsNullOrEmpty(notification.TargetUrl))
                {
                    <a href="@notification.TargetUrl" onclick="markAsRead('@notification.Id')" class="text-xs font-bold text-brand-primary hover:underline">
                        @(notification.Title.Contains("resolved", StringComparison.OrdinalIgnoreCase) ? L["View Resolution"] : L["View Ticket"])
                    </a>
                }
                @if (!notification.IsRead)
                {
                    <button onclick="markAsRead('@notification.Id')" class="text-xs font-bold text-slate-400 hover:text-slate-600">
                        @L["Mark as read"]
                    </button>
                }
            </div>
        </div>
        @if (!notification.IsRead)
        {
            <div class="h-2 w-2 rounded-full bg-blue-500 mt-2" id="dot-@notification.Id"></div>
        }
    </div>
}

@if (Model.HasMore)
{
    <div id="load-more-container" class="bg-slate-50 p-6 text-center border-t border-slate-100">
        <button onclick="loadMore()" id="load-more-btn" class="text-sm font-bold text-slate-500 hover:text-slate-800 transition-colors">
            @L["Load older notifications"]
        </button>
    </div>
}
