@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.AspNetCore.Identity
@using TicketsPlease.Application.Common.Interfaces
@using TicketsPlease.Domain.Entities
@using Microsoft.EntityFrameworkCore
@inject ICorporateSkinProvider SkinProvider
@inject IViewLocalizer L
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager
@inject INotificationService NotificationService
@inject IMessageService MessageService
@inject IUserRepository UserRepository

@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    User user = null;
    string initials = "??";
    string avatarUrl = null;
    var unreadNotifications = new List<TicketsPlease.Application.Common.Dtos.NotificationDto>();
    var latestMessages = new List<TicketsPlease.Application.Common.Dtos.MessageDto>();

    if (SignInManager.IsSignedIn(User))
    {
        var userId = UserManager.GetUserId(User);
        if (!string.IsNullOrEmpty(userId))
        {
            user = await UserManager.Users
                .Include(u => u.Profile)
                .FirstOrDefaultAsync(u => u.Id == Guid.Parse(userId));

            if (user != null)
            {
                initials = user.UserName?.Length >= 2 ? user.UserName.Substring(0, 2).ToUpper() : (user.UserName?.ToUpper() ?? "??");
                avatarUrl = user.Profile?.AvatarUrl?.ToString();
                unreadNotifications = (await NotificationService.GetNotificationsForUserAsync(user.Id, 10))
                    .Where(n => !n.IsRead)
                    .ToList();

                latestMessages = await MessageService.GetLatestUserMessagesAsync(user.Id, 5);
            }
        }
    }

    string GetActiveClass(string controller) => currentController == controller
        ? "border-brand-primary text-slate-900"
        : "border-transparent text-slate-500 hover:border-slate-300 hover:text-slate-700";
}

<header class="bg-white/80 backdrop-blur-md border-b border-slate-200 sticky top-0 z-50">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8" aria-label="Main Navigation">
        <div class="flex justify-between h-16">
            <div class="flex">
                @* Logo Section *@
                <div class="flex-shrink-0 flex items-center">
                    <a asp-controller="Home" asp-action="Index" class="text-2xl font-bold text-brand-primary hover:scale-105 transition-transform duration-200" aria-label="TicketsPlease Home">
                        <i class="fa-solid fa-ticket mr-2 fa-bounce" style="--fa-animation-iteration-count: 2;"></i>
                        <span class="hidden md:inline">@SkinProvider.GetLogoName()</span>
                    </a>
                </div>

                @* Desktop Navigation *@
                <div class="hidden sm:ml-8 sm:flex sm:space-x-8">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <a asp-controller="Home" asp-action="Index"
                           class="inline-flex items-center px-1 pt-1 border-b-2 @GetActiveClass("Home") text-sm font-medium transition-colors duration-200">
                            <i class="fa-solid fa-house-chimney mr-2 @(currentController == "Home" ? "text-brand-primary" : "text-slate-400")"></i>
                            @L["Dashboard"]
                        </a>
                        <a asp-controller="Tickets" asp-action="Index"
                           class="inline-flex items-center px-1 pt-1 border-b-2 @GetActiveClass("Tickets") text-sm font-medium transition-colors duration-200">
                            <i class="fa-solid fa-ticket mr-2 @(currentController == "Tickets" ? "text-brand-primary" : "text-slate-400")"></i>
                            @L["Tickets"]
                        </a>
                        <a asp-controller="Teams" asp-action="Index"
                           class="inline-flex items-center px-1 pt-1 border-b-2 @GetActiveClass("Teams") text-sm font-medium transition-colors duration-200">
                            <i class="fa-solid fa-users mr-2 @(currentController == "Teams" ? "text-brand-primary" : "text-slate-400")"></i>
                            @L["Teams"]
                        </a>
                        <a asp-controller="Messages" asp-action="Index"
                           class="inline-flex items-center px-1 pt-1 border-b-2 @GetActiveClass("Messages") text-sm font-medium transition-colors duration-200" aria-label="@L["Messages"]">
                            <i class="fa-solid fa-comment-dots mr-2 @(currentController == "Messages" ? "text-brand-primary" : "text-slate-400")"></i>
                            @L["Messages"]
                        </a>
                    }
                </div>
            </div>

            @* User Menu & Actions *@
            <div class="flex items-center space-x-2">
                @if (SignInManager.IsSignedIn(User))
                {
                    @* Collaboration Hub Button *@
                    <button onclick="toggleChat()" class="text-slate-500 hover:text-indigo-600 transition-all duration-300 relative p-2 rounded-xl hover:bg-indigo-50 cursor-pointer focus:outline-none flex items-center gap-2 group border border-transparent hover:border-indigo-100" aria-label="@L["Collaboration Hub"]">
                        <div class="relative">
                            <i class="fa-solid fa-cloud-bolt text-xl group-hover:scale-110 transition-transform"></i>
                            <span class="absolute -top-1 -right-1 flex h-2 w-2">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
                            </span>
                        </div>
                        <span class="text-xs font-black uppercase tracking-widest hidden lg:block">Hub</span>
                    </button>

                    @* Chat Dropdown *@
                    <div class="relative">
                        <details class="group list-none">
                            <summary class="text-slate-500 hover:text-brand-primary transition-colors duration-200 relative p-2 rounded-full hover:bg-slate-100 cursor-pointer focus:outline-none list-none" aria-label="@L["Messages"]">
                                <i class="fa-solid fa-comment-dots text-xl fa-bounce-hover"></i>
                                @if (latestMessages.Any())
                                {
                                    <span class="absolute top-1.5 right-1.5 block h-2.5 w-2.5 rounded-full bg-blue-500 ring-2 ring-white"></span>
                                }
                            </summary>
                            <div class="absolute right-0 mt-2 w-80 origin-top-right rounded-xl bg-white p-4 shadow-2xl ring-1 ring-slate-200 focus:outline-none z-50 animate-in fade-in zoom-in duration-200">
                                <div class="flex items-center justify-between mb-4 pb-2 border-b border-slate-100">
                                    <h3 class="text-xs font-bold text-slate-900 uppercase tracking-widest">@L["Messages"]</h3>
                                    <span class="text-[10px] bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full font-bold">@latestMessages.Count</span>
                                </div>
                                <div class="space-y-3 max-h-64 overflow-y-auto custom-scrollbar">
                                    @if (!latestMessages.Any())
                                    {
                                        <p class="text-[10px] text-slate-400 text-center py-4">@L["No new messages"]</p>
                                    }
                                    @foreach (var msg in latestMessages)
                                    {
                                        <a asp-controller="Messages" asp-action="Conversation" asp-route-userId="@(msg.SenderUserId == user.Id ? msg.ReceiverUserId : msg.SenderUserId)" class="flex items-start gap-3 p-2 rounded-lg hover:bg-slate-50 transition-colors cursor-pointer block">
                                            <div class="h-8 w-8 rounded-full bg-slate-100 flex items-center justify-center text-slate-400 flex-shrink-0">
                                                <i class="fa-solid fa-user text-xs"></i>
                                            </div>
                                            <div class="min-w-0 flex-1">
                                                <div class="flex items-center justify-between">
                                                    <p class="text-xs font-bold text-slate-800 truncate">@(msg.SenderUserId == user.Id ? msg.ReceiverUserName : msg.SenderUserName)</p>
                                                    <span class="text-[9px] text-slate-400">@msg.SentAt.ToShortTimeString()</span>
                                                </div>
                                                <p class="text-[10px] text-slate-500 truncate">@msg.BodyMarkdown</p>
                                            </div>
                                        </a>
                                    }
                                </div>
                                <div class="mt-4 pt-2 border-t border-slate-100">
                                    <a asp-controller="Messages" asp-action="Index" class="text-[10px] font-bold text-brand-primary hover:text-brand-secondary transition-colors uppercase tracking-widest text-center block">@L["See all messages"]</a>
                                </div>
                            </div>
                        </details>
                    </div>

                    @* Notifications Dropdown *@
                    <div class="relative">
                        <details class="group list-none">
                            <summary class="text-slate-500 hover:text-brand-primary transition-colors duration-200 relative p-2 rounded-full hover:bg-slate-100 cursor-pointer focus:outline-none list-none" aria-label="@L["Notifications"]">
                                <i class="fa-solid fa-bell text-xl fa-shake-hover"></i>
                                @if (unreadNotifications.Any())
                                {
                                    <span id="nav-noti-dot" class="absolute top-1.5 right-1.5 block h-2.5 w-2.5 rounded-full bg-red-500 ring-2 ring-white group-hover:animate-pulse"></span>
                                }
                            </summary>
                            <div class="absolute right-0 mt-2 w-80 origin-top-right rounded-xl bg-white p-4 shadow-2xl ring-1 ring-slate-200 focus:outline-none z-50 animate-in fade-in zoom-in duration-200">
                                <div class="flex items-center justify-between mb-4 pb-2 border-b border-slate-100">
                                    <h3 class="text-xs font-bold text-slate-900 uppercase tracking-widest">@L["Notifications"]</h3>
                                    <span id="nav-noti-count" class="text-[10px] bg-brand-primary/10 text-brand-primary px-2 py-0.5 rounded-full font-bold">@unreadNotifications.Count @L["New"]</span>
                                </div>
                                <div class="space-y-3 max-h-64 overflow-y-auto custom-scrollbar" id="nav-noti-list">
                                    @if (!unreadNotifications.Any())
                                    {
                                        <p class="text-[10px] text-slate-400 text-center py-4">@L["No new notifications"]</p>
                                    }
                                    @foreach (var noti in unreadNotifications)
                                    {
                                        <a href="@(string.IsNullOrEmpty(noti.TargetUrl) ? "/Notifications" : noti.TargetUrl)" class="flex items-start gap-3 p-2 rounded-lg hover:bg-slate-50 transition-colors cursor-pointer block">
                                            <div class="h-8 w-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 flex-shrink-0">
                                                @if (noti.Title.Contains("ticket", StringComparison.OrdinalIgnoreCase)) { <i class="fa-solid fa-ticket text-xs"></i> }
                                                else if (noti.Title.Contains("comment", StringComparison.OrdinalIgnoreCase)) { <i class="fa-solid fa-comment-dots text-xs"></i> }
                                                else { <i class="fa-solid fa-bell text-xs"></i> }
                                            </div>
                                            <div>
                                                <p class="text-xs font-bold text-slate-800">@noti.Title</p>
                                                <p class="text-[10px] text-slate-500 line-clamp-2">@noti.Content</p>
                                            </div>
                                        </a>
                                    }
                                </div>
                                <div class="mt-4 pt-2 border-t border-slate-100">
                                    <a asp-controller="Notifications" asp-action="Index" class="text-[10px] font-bold text-brand-primary hover:text-brand-secondary transition-colors uppercase tracking-widest text-center block">@L["See all notifications"]</a>
                                </div>
                            </div>
                        </details>
                    </div>

                    @* Profile Dropdown (Jump List) *@
                    <div class="relative ml-3">
                        <details class="group list-none">
                            <summary class="flex items-center cursor-pointer focus:outline-none list-none" aria-haspopup="true" aria-expanded="false">
                                <partial name="_Avatar" model='initials' view-data='@new ViewDataDictionary(ViewData) { { "SizeClass", "h-9 w-9" }, { "AvatarUrl", avatarUrl } }' />
                                <i class="fa-solid fa-chevron-down ml-2 text-slate-400 text-xs group-open:rotate-180 transition-transform duration-200"></i>
                            </summary>

                            <div class="absolute right-0 mt-2 w-56 origin-top-right rounded-xl bg-white p-2 shadow-2xl ring-1 ring-slate-200 focus:outline-none z-50 animate-in fade-in zoom-in duration-200">
                                <div class="px-3 py-2 border-b border-slate-100 mb-2">
                                    <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider">@L["Account"]</p>
                                    <p class="text-sm font-bold text-slate-900 truncate">@(user?.UserName ?? "User")</p>
                                </div>

                                <a asp-controller="Account" asp-action="Profile" class="flex items-center px-3 py-2 text-sm text-slate-700 rounded-lg hover:bg-slate-50 hover:text-brand-primary transition-colors duration-150">
                                    <i class="fa-solid fa-user-gear mr-3 text-slate-400 w-5"></i>
                                    @L["Profile"]
                                </a>
                                <a asp-controller="Messages" asp-action="Index" class="flex items-center px-3 py-2 text-sm text-slate-700 rounded-lg hover:bg-slate-50 hover:text-brand-primary transition-colors duration-150">
                                    <i class="fa-solid fa-envelope mr-3 text-slate-400 w-5"></i>
                                    @L["My Messages"]
                                </a>

                                @if (User.IsInRole("Admin"))
                                {
                                    <div class="mt-2 pt-2 border-t border-slate-100">
                                        <p class="px-3 text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-1">@L["Administration"]</p>
                                        <a asp-controller="Project" asp-action="Index" class="flex items-center px-3 py-2 text-sm text-slate-700 rounded-lg hover:bg-slate-50 hover:text-brand-primary transition-colors duration-150">
                                            <i class="fa-solid fa-diagram-project mr-3 text-slate-400 w-5"></i>
                                            @L["Project Management"]
                                        </a>
                                        <a asp-controller="AdminUsers" asp-action="Index" class="flex items-center px-3 py-2 text-sm text-slate-700 rounded-lg hover:bg-amber-50 hover:text-amber-600 transition-colors duration-150">
                                            <i class="fa-solid fa-user-shield mr-3 text-amber-500/60 w-5"></i>
                                            @L["User Management"]
                                        </a>
                                        <a asp-controller="Admin" asp-action="Settings" class="flex items-center px-3 py-2 text-sm text-slate-700 rounded-lg hover:bg-slate-50 hover:text-brand-primary transition-colors duration-150">
                                            <i class="fa-solid fa-gears mr-3 text-slate-400 w-5"></i>
                                            @L["Settings"]
                                        </a>
                                        <a asp-controller="AdminTemplates" asp-action="Index" class="flex items-center px-3 py-2 text-sm text-slate-700 rounded-lg hover:bg-slate-50 hover:text-brand-primary transition-colors duration-150">
                                            <i class="fa-solid fa-file-invoice mr-3 text-slate-400 w-5"></i>
                                            @L["Ticket Templates"]
                                        </a>
                                        <a asp-controller="AdminWorkspaces" asp-action="Index" class="flex items-center px-3 py-2 text-sm text-slate-700 rounded-lg hover:bg-slate-50 hover:text-brand-primary transition-colors duration-150">
                                            <i class="fa-solid fa-hotel mr-3 text-slate-400 w-5"></i>
                                            @L["Workspace Management"]
                                        </a>
                                    </div>
                                }

                                @if (User.IsInRole("Admin") || User.IsInRole("Teamlead"))
                                {
                                    <div class="mt-2 pt-2 border-t border-slate-100">
                                        <a asp-controller="Teams" asp-action="Management" class="flex items-center px-3 py-2 text-sm text-slate-700 rounded-lg hover:bg-indigo-50 hover:text-indigo-600 transition-colors duration-150">
                                            <i class="fa-solid fa-users-gear mr-3 text-indigo-500/60 w-5"></i>
                                            @L["Team Management"]
                                        </a>
                                    </div>
                                }

                                <div class="mt-2 pt-2 border-t border-slate-100">
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                                        <button type="submit" class="w-full flex items-center px-3 py-2 text-sm text-red-600 rounded-lg hover:bg-red-50 transition-colors duration-150">
                                            <i class="fa-solid fa-right-from-bracket mr-3 text-red-400 w-5"></i>
                                            @L["Logout"]
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </details>
                    </div>
                }
                else
                {
                    <div class="flex items-center space-x-3">
                        <a asp-controller="Account" asp-action="Login" class="text-sm font-semibold text-slate-600 hover:text-brand-primary transition-colors">
                            @L["Login"]
                        </a>
                        <a asp-controller="Account" asp-action="Register" class="inline-flex items-center justify-center px-4 py-2 text-sm font-bold text-white bg-brand-primary rounded-full hover:bg-brand-secondary hover:shadow-lg hover:shadow-brand-primary/30 transition-all duration-200">
                            <i class="fa-solid fa-user-plus mr-2"></i>
                            @L["Get Started"]
                        </a>
                    </div>
                }
            </div>
        </div>
    </nav>
</header>
