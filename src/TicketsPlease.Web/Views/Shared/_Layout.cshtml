@using Microsoft.AspNetCore.Mvc.Localization
@using TicketsPlease.Application.Common.Interfaces
@inject ICorporateSkinProvider SkinProvider
@inject IViewLocalizer L

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName" class="h-full">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="@(ViewData["Description"] ?? "TicketsPlease - The ultimate project board for modern teams. Manage tasks, projects and performance with ease.")" />
    <meta name="robots" content="index, follow" />
    <title>@(ViewData["Title"] ?? "TicketsPlease") | BitLC-NE Solutions</title>
    @await RenderSectionAsync("Meta", required: false)

    @* Tailwind CSS Output & Site Specific Styles *@
    <link rel="stylesheet" href="~/css/app.css"/>
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.min.css" />
    <link rel="stylesheet" href="~/lib/noto-sans-variable/index.css" />
    <link rel="stylesheet" href="~/lib/roboto-flex/index.css" />
    <link rel="stylesheet" href="~/lib/google-sans-flex/index.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TicketsPlease.Web.styles.css" asp-append-version="true" />

    @* FontAwesome 7.2 (Lokal via LibMan) *@
    @* Noto Sans Variable (Lokal via LibMan) *@

    @* Dynamisches Corporate Skinning via CSS-Variablen *@
    <style>
        :root {
            --brand-primary: @SkinProvider.GetPrimaryColor();
            --brand-secondary: @SkinProvider.GetSecondaryColor();
        }
    </style>
</head>
<body class="h-full bg-slate-50 text-slate-900 flex flex-col">
    <partial name="_Navbar" />

    <main class="flex-grow">
        <partial name="_Notification" model='TempData.Peek("Notification")' />
        <div class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
            @RenderBody()
        </div>
    </main>

    <partial name="_Footer" />
    <partial name="_CookieBanner" />

    <div id="enterprise-toast-container" class="enterprise-toast-container"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/signalr/dist/browser/signalr.min.js"></script>
    <script src="~/lib/dompurify/dist/purify.min.js"></script>
    <script src="~/lib/marked/marked.min.js"></script>
    <script src="~/lib/mermaid/dist/mermaid.min.js"></script>
    <script src="~/js/markdown-engine.js" asp-append-version="true"></script>
    <script src="~/js/notification-client.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    
    @if (User.Identity?.IsAuthenticated == true)
    {
        <script>window.currentUserName = "@User.Identity.Name";</script>
        <partial name="_CollaborationHub" />
        <script src="~/js/collaboration-client.js" asp-append-version="true"></script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
