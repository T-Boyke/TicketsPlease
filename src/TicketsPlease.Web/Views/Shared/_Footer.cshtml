@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer L

<footer class="bg-white border-t border-slate-200 py-10" aria-label="Global Footer">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 items-center text-slate-500 text-sm">
            <div class="text-center md:text-left">
                <p>&copy; @DateTime.Now.Year - <span class="font-bold text-slate-700">TicketsPlease</span> - Modern Kanban</p>
            </div>
            
            <div class="flex flex-col items-center justify-center space-y-2">
                <div class="flex items-center space-x-1 text-slate-400">
                    <i class="fa-solid fa-code text-xs"></i>
                    <span>@L["Coded by"]</span>
                    <a href="https://github.com/T-Boyke" 
                       class="font-bold text-brand-primary hover:text-brand-secondary transition-colors duration-200 flex items-center group"
                       target="_blank" 
                       rel="noopener noreferrer"
                       aria-label="T-Boyke on GitHub">
                        T-Boyke
                        <i class="fa-brands fa-github ml-1.5 text-lg group-hover:fa-spin transition-all"></i>
                    </a>
                </div>
                @* Language Switcher *@
                <div class="flex items-center gap-4 text-xs font-bold uppercase tracking-widest text-slate-400">
                    <a href="?culture=de" class="@(System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "de" ? "text-brand-primary border-b-2 border-brand-primary" : "hover:text-slate-600 transition-colors")" aria-label="Switch to German">DE</a>
                    <span class="w-1 h-1 rounded-full bg-slate-200"></span>
                    <a href="?culture=en" class="@(System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName == "en" ? "text-brand-primary border-b-2 border-brand-primary" : "hover:text-slate-600 transition-colors")" aria-label="Switch to English">EN</a>
                </div>
            </div>

            <div class="flex justify-center md:justify-end space-x-6 h-full items-center">
                <a asp-controller="Home" asp-action="Privacy" 
                   class="hover:text-brand-primary transition-colors duration-200"
                   aria-label="@L["Go to Privacy Policy"]">@L["Privacy"]</a>
                <a asp-controller="Styleguide" asp-action="Index" 
                   class="bg-brand-primary/5 text-brand-primary px-3 py-1 rounded-full font-bold hover:bg-brand-primary hover:text-white transition-all duration-300 flex items-center"
                   aria-label="@L["Open Styleguide"]">
                    <i class="fa-solid fa-wand-magic-sparkles mr-2 fa-fade"></i>
                    Styleguide
                </a>
                <a asp-controller="Home" asp-action="Impressum" 
                   class="hover:text-brand-primary transition-colors duration-200"
                   aria-label="@L["Go to Imprint"]">@L["Imprint"]</a>
            </div>
        </div>
    </div>
</footer>
