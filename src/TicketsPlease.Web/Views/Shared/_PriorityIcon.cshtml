@model int
@{
    // Priority Logic for "Chillischoten-Metrik" 🌶️
    // 1: Low, 2: Medium, 3: High, 4: Blocker, 5: Critical
    var count = Model;
    var colorClass = count switch {
        1 => "text-slate-400",
        2 => "text-blue-500",
        3 => "text-orange-500",
        4 => "text-red-500",
        5 => "text-purple-600 animate-pulse",
        _ => "text-slate-300"
    };
    
    var ariaLabel = count switch {
        1 => "Priorität: Niedrig",
        2 => "Priorität: Mittel",
        3 => "Priorität: Hoch",
        4 => "Priorität: Blocker",
        5 => "Priorität: Kritisch (Sofort handeln!)",
        _ => "Priorität: Unbekannt"
    };
}

<div class="flex space-x-0.5 @colorClass" role="img" aria-label="@ariaLabel">
    @for (int i = 0; i < 5; i++)
    {
        if (i < count)
        {
            <i class="fa-solid fa-pepper-hot text-[10px]"></i>
        }
        else
        {
            <i class="fa-solid fa-pepper-hot text-[10px] opacity-20"></i>
        }
    }
</div>
