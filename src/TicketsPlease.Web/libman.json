{
  "version": "1.0",
  "defaultProvider": "unpkg",
  "libraries": [
    {
      "library": "@fortawesome/fontawesome-free@7.2.0",
      "destination": "wwwroot/lib/font-awesome",
      "files": [
        "css/all.min.css",
        "webfonts/fa-solid-900.woff2",
        "webfonts/fa-regular-400.woff2",
        "webfonts/fa-brands-400.woff2",
        "webfonts/fa-v4compatibility.woff2"
      ]
    },
    {
      "library": "@microsoft/signalr@8.0.7",
      "destination": "wwwroot/lib/signalr",
      "files": [
        "dist/browser/signalr.min.js"
      ]
    },
    {
      "library": "marked@15.0.7",
      "destination": "wwwroot/lib/marked",
      "files": [
        "marked.min.js"
      ]
    },
    {
      "library": "dompurify@3.2.4",
      "destination": "wwwroot/lib/dompurify",
      "files": [
        "dist/purify.min.js"
      ]
    },
    {
      "library": "mermaid@11.4.1",
      "destination": "wwwroot/lib/mermaid",
      "files": [
        "dist/mermaid.min.js"
      ]
    },
    {
      "library": "sortablejs@1.15.6",
      "destination": "wwwroot/lib/sortablejs",
      "files": [
        "Sortable.min.js"
      ]
    }
  ]
}
